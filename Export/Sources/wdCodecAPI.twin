    Static iid As UUID
     If (iid.Data1 = 0) Then Call DEFINE_UUID(iid, &Hd6d6c6d1, &H064e, &H4fdd, &Ha4, &H0e, &H3e, &Hcb, &Hfc, &Hb7, &Heb, &Hd0)
