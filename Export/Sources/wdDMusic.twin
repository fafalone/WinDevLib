Public Enum DMusicIoInstrumentFlags
	DMUS_IO_INST_PATCH = (1 << 0) /* dwPatch is valid. */
	DMUS_IO_INST_BANKSELECT = (1 << 1) /* dwPatch contains a valid Bank Select MSB and LSB part */
	DMUS_IO_INST_ASSIGN_PATCH = (1 << 3) /* dwAssignPatch is valid */
	DMUS_IO_INST_NOTERANGES = (1 << 4) /* dwNoteRanges is valid */
	DMUS_IO_INST_PAN = (1 << 5) /* bPan is valid */
	DMUS_IO_INST_VOLUME = (1 << 6) /* bVolume is valid */
	DMUS_IO_INST_TRANSPOSE = (1 << 7) /* nTranspose is valid */
	DMUS_IO_INST_GM = (1 << 8) /* Instrument is from GM collection */
	DMUS_IO_INST_GS = (1 << 9) /* Instrument is from GS collection */
	DMUS_IO_INST_XG = (1 << 10) /* Instrument is from XG collection */
	DMUS_IO_INST_CHANNEL_PRIORITY = (1 << 11) /* dwChannelPriority is valid */
	DMUS_IO_INST_USE_DEFAULT_GM_SET = (1 << 12) /* Always use the default GM set for this patch, */
	don't  = rely on the synth caps stating GM or GS in hardware. */
	DMUS_IO_INST_PITCHBENDRANGE = (1 << 13) /* nPitchBendRange is valid */
End Enum

Public Type DMUS_IO_INSTRUMENT
	dwPatch As Long '* MSB, LSB and Program change to define instrument */
	dwAssignPatch As Long '* MSB, LSB and Program change to assign to instrument when downloading */
	dwNoteRanges(0 To 3) As Long '* 128 bits; one for each MIDI note instrument needs to able to play */
	dwPChannel As Long '* PChannel instrument plays on */
	dwFlags As DMusicIoInstrumentFlags '* DMUS_IO_INST_ flags */
	bPan As Byte '* Pan for instrument */
	bVolume As Byte '* Volume for instrument */
	nTranspose As Integer '* Number of semitones to transpose notes */
	dwChannelPriority As Long '* Channel priority */
	nPitchBendRange As Integer '* Number of semitones shifted by pitch bend */
End Type

