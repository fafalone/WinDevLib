Public Const DMUS_E_ALREADY_LOADED           = &H88781111 'MAKE_DMHRESULTERROR(0x0111)

/* DMUS_E_INVALIDPOS
*
* Error reading wave data from DLS collection. Indicates bad file.
*/
Public Const DMUS_E_INVALIDPOS               = &H88781113 'MAKE_DMHRESULTERROR(0x0113)

/* DMUS_E_INVALIDPATCH
*
* There is no instrument in the collection that matches patch number.
*/
Public Const DMUS_E_INVALIDPATCH             = &H88781114 'MAKE_DMHRESULTERROR(0x0114)

/* DMUS_E_CANNOTSEEK
*
* The IStream* doesn't support Seek().
*/
Public Const DMUS_E_CANNOTSEEK               = &H88781115 'MAKE_DMHRESULTERROR(0x0115)

/* DMUS_E_CANNOTWRITE
*
* The IStream* doesn't support Write().
*/
Public Const DMUS_E_CANNOTWRITE              = &H88781116 'MAKE_DMHRESULTERROR(0x0116)

/* DMUS_E_CHUNKNOTFOUND
*
* The RIFF parser doesn't contain a required chunk while parsing file.
*/
Public Const DMUS_E_CHUNKNOTFOUND            = &H88781117 'MAKE_DMHRESULTERROR(0x0117)

/* DMUS_E_INVALID_DOWNLOADID
*
* Invalid download id was used in the process of creating a download buffer.
*/
Public Const DMUS_E_INVALID_DOWNLOADID       = &H88781119 'MAKE_DMHRESULTERROR(0x0119)

/* DMUS_E_NOT_DOWNLOADED_TO_PORT
*
* Tried to unload an object that was not downloaded or previously unloaded.
*/
Public Const DMUS_E_NOT_DOWNLOADED_TO_PORT   = &H88781120 'MAKE_DMHRESULTERROR(0x0120)

/* DMUS_E_ALREADY_DOWNLOADED
*
* Buffer was already downloaded to synth.
*/
Public Const DMUS_E_ALREADY_DOWNLOADED       = &H88781121 'MAKE_DMHRESULTERROR(0x0121)

/* DMUS_E_UNKNOWN_PROPERTY
*
* The specified property item was not recognized by the target object.
*/
Public Const DMUS_E_UNKNOWN_PROPERTY         = &H88781122 'MAKE_DMHRESULTERROR(0x0122)

/* DMUS_E_SET_UNSUPPORTED
*
* The specified property item may not be set on the target object.
*/
Public Const DMUS_E_SET_UNSUPPORTED          = &H88781123 'MAKE_DMHRESULTERROR(0x0123)

/* DMUS_E_GET_UNSUPPORTED
*
* The specified property item may not be retrieved from the target object.
*/
Public Const DMUS_E_GET_UNSUPPORTED          = &H88781124 'MAKE_DMHRESULTERROR(0x0124)

/* DMUS_E_NOTMONO
*
* Wave chunk has more than one interleaved channel. DLS format requires MONO.
*/
Public Const DMUS_E_NOTMONO                  = &H88781125 'MAKE_DMHRESULTERROR(0x0125)

/* DMUS_E_BADARTICULATION
*
* Invalid articulation chunk in DLS collection.
*/
Public Const DMUS_E_BADARTICULATION          = &H88781126 'MAKE_DMHRESULTERROR(0x0126)

/* DMUS_E_BADINSTRUMENT
*
* Invalid instrument chunk in DLS collection.
*/
Public Const DMUS_E_BADINSTRUMENT            = &H88781127 'MAKE_DMHRESULTERROR(0x0127)

/* DMUS_E_BADWAVELINK
*
* Wavelink chunk in DLS collection points to invalid wave.
*/
Public Const DMUS_E_BADWAVELINK              = &H88781128 'MAKE_DMHRESULTERROR(0x0128)

/* DMUS_E_NOARTICULATION
*
* Articulation missing from instrument in DLS collection.
*/
Public Const DMUS_E_NOARTICULATION           = &H88781129 'MAKE_DMHRESULTERROR(0x0129)

/* DMUS_E_NOTPCM
*
* Downoaded DLS wave is not in PCM format. 
*/
Public Const DMUS_E_NOTPCM                   = &H8878112a 'MAKE_DMHRESULTERROR(0x012A)

/* DMUS_E_BADWAVE
*
* Bad wave chunk in DLS collection
*/
Public Const DMUS_E_BADWAVE                  = &H8878112b 'MAKE_DMHRESULTERROR(0x012B)

/* DMUS_E_BADOFFSETTABLE
*
* Offset Table for download buffer has errors. 
*/
Public Const DMUS_E_BADOFFSETTABLE           = &H8878112c 'MAKE_DMHRESULTERROR(0x012C)

/* DMUS_E_UNKNOWNDOWNLOAD
*
* Attempted to download unknown data type.
*/
Public Const DMUS_E_UNKNOWNDOWNLOAD          = &H8878112d 'MAKE_DMHRESULTERROR(0x012D)

/* DMUS_E_NOSYNTHSINK
*
* The operation could not be completed because no sink was connected to
* the synthesizer.
*/
Public Const DMUS_E_NOSYNTHSINK              = &H8878112e 'MAKE_DMHRESULTERROR(0x012E)

/* DMUS_E_ALREADYOPEN
*
* An attempt was made to open the software synthesizer while it was already 
* open.
* ASSERT?
*/
Public Const DMUS_E_ALREADYOPEN              = &H8878112f 'MAKE_DMHRESULTERROR(0x012F)

/* DMUS_E_ALREADYCLOSE
*
* An attempt was made to close the software synthesizer while it was already 
* open.
* ASSERT?
*/
Public Const DMUS_E_ALREADYCLOSED            = &H88781130 'MAKE_DMHRESULTERROR(0x0130)

/* DMUS_E_SYNTHNOTCONFIGURED
*
* The operation could not be completed because the software synth has not 
* yet been fully configured.
* ASSERT?
*/
Public Const DMUS_E_SYNTHNOTCONFIGURED       = &H88781131 'MAKE_DMHRESULTERROR(0x0131)

/* DMUS_E_SYNTHACTIVE
*
* The operation cannot be carried out while the synthesizer is active.
*/
Public Const DMUS_E_SYNTHACTIVE              = &H88781132 'MAKE_DMHRESULTERROR(0x0132)

/* DMUS_E_CANNOTREAD
*
* An error occurred while attempting to read from the IStream* object.
*/
Public Const DMUS_E_CANNOTREAD               = &H88781133 'MAKE_DMHRESULTERROR(0x0133)

/* DMUS_E_DMUSIC_RELEASED
*
* The operation cannot be performed because the final instance of the
* DirectMusic object was released. Ports cannot be used after final 
* release of the DirectMusic object.
*/
Public Const DMUS_E_DMUSIC_RELEASED          = &H88781134 'MAKE_DMHRESULTERROR(0x0134)

/* DMUS_E_BUFFER_EMPTY
*
* There was no data in the referenced buffer.
*/
Public Const DMUS_E_BUFFER_EMPTY             = &H88781135 'MAKE_DMHRESULTERROR(0x0135)

/* DMUS_E_BUFFER_FULL
*
* There is insufficient space to insert the given event into the buffer.
*/
Public Const DMUS_E_BUFFER_FULL              = &H88781136 'MAKE_DMHRESULTERROR(0x0136)

/* DMUS_E_PORT_NOT_CAPTURE
*
* The given operation could not be carried out because the port is a
* capture port.
*/
Public Const DMUS_E_PORT_NOT_CAPTURE         = &H88781137 'MAKE_DMHRESULTERROR(0x0137)

/* DMUS_E_PORT_NOT_RENDER
*
* The given operation could not be carried out because the port is a
* render port.
*/
Public Const DMUS_E_PORT_NOT_RENDER          = &H88781138 'MAKE_DMHRESULTERROR(0x0138)

/* DMUS_E_DSOUND_NOT_SET
*
* The port could not be created because no DirectSound has been specified.
* Specify a DirectSound interface via the IDirectMusic::SetDirectSound
* method; pass NULL to have DirectMusic manage usage of DirectSound.
*/
Public Const DMUS_E_DSOUND_NOT_SET           = &H88781139 'MAKE_DMHRESULTERROR(0x0139)

/* DMUS_E_ALREADY_ACTIVATED
*
* The operation cannot be carried out while the port is active.
*/
Public Const DMUS_E_ALREADY_ACTIVATED        = &H8878113a 'MAKE_DMHRESULTERROR(0x013A)

/* DMUS_E_INVALIDBUFFER
*
* Invalid DirectSound buffer was handed to port. 
*/
Public Const DMUS_E_INVALIDBUFFER            = &H8878113b 'MAKE_DMHRESULTERROR(0x013B)

/* DMUS_E_WAVEFORMATNOTSUPPORTED
*
* Invalid buffer format was handed to the synth sink.
*/
Public Const DMUS_E_WAVEFORMATNOTSUPPORTED   = &H8878113c 'MAKE_DMHRESULTERROR(0x013C)

/* DMUS_E_SYNTHINACTIVE
*
* The operation cannot be carried out while the synthesizer is inactive.
*/
Public Const DMUS_E_SYNTHINACTIVE            = &H8878113d 'MAKE_DMHRESULTERROR(0x013D)

/* DMUS_E_DSOUND_ALREADY_SET
*
* IDirectMusic::SetDirectSound has already been called. It may not be
* changed while in use.
*/
Public Const DMUS_E_DSOUND_ALREADY_SET       = &H8878113e 'MAKE_DMHRESULTERROR(0x013E)

/* DMUS_E_INVALID_EVENT
*
* The given event is invalid (either it is not a valid MIDI message
* or it makes use of running status). The event cannot be packed
* into the buffer.
*/
Public Const DMUS_E_INVALID_EVENT            = &H8878113f 'MAKE_DMHRESULTERROR(0x013F)

/* DMUS_E_UNSUPPORTED_STREAM
*
* The IStream* object does not contain data supported by the loading object.
*/
Public Const DMUS_E_UNSUPPORTED_STREAM       = &H88781150 'MAKE_DMHRESULTERROR(0x0150)

/* DMUS_E_ALREADY_INITED
*
* The object has already been initialized.
*/
Public Const DMUS_E_ALREADY_INITED           = &H88781151 'MAKE_DMHRESULTERROR(0x0151)

/* DMUS_E_INVALID_BAND
*
* The file does not contain a valid band.
*/
Public Const DMUS_E_INVALID_BAND             = &H88781152 'MAKE_DMHRESULTERROR(0x0152)

/* DMUS_E_TRACK_HDR_NOT_FIRST_CK
*
* The IStream* object's data does not have a track header as the first chunk,
* and therefore can not be read by the segment object.
*/
Public Const DMUS_E_TRACK_HDR_NOT_FIRST_CK   = &H88781155 'MAKE_DMHRESULTERROR(0x0155)

/* DMUS_E_TOOL_HDR_NOT_FIRST_CK
*
* The IStream* object's data does not have a tool header as the first chunk,
* and therefore can not be read by the graph object.
*/
Public Const DMUS_E_TOOL_HDR_NOT_FIRST_CK    = &H88781156 'MAKE_DMHRESULTERROR(0x0156)

/* DMUS_E_INVALID_TRACK_HDR
*
* The IStream* object's data contains an invalid track header (ckid is 0 and
* fccType is NULL,) and therefore can not be read by the segment object.
*/
Public Const DMUS_E_INVALID_TRACK_HDR        = &H88781157 'MAKE_DMHRESULTERROR(0x0157)

/* DMUS_E_INVALID_TOOL_HDR
*
* The IStream* object's data contains an invalid tool header (ckid is 0 and
* fccType is NULL,) and therefore can not be read by the graph object.
*/
Public Const DMUS_E_INVALID_TOOL_HDR         = &H88781158 'MAKE_DMHRESULTERROR(0x0158)

/* DMUS_E_ALL_TOOLS_FAILED
*
* The graph object was unable to load all tools from the IStream* object data.
* This may be due to errors in the stream, or the tools being incorrectly
* registered on the client.
*/
Public Const DMUS_E_ALL_TOOLS_FAILED         = &H88781159 'MAKE_DMHRESULTERROR(0x0159)

/* DMUS_E_ALL_TRACKS_FAILED
*
* The segment object was unable to load all tracks from the IStream* object data.
* This may be due to errors in the stream, or the tracks being incorrectly
* registered on the client.
*/
Public Const DMUS_E_ALL_TRACKS_FAILED        = &H88781160 'MAKE_DMHRESULTERROR(0x0160)

/* DMUS_E_NOT_FOUND
*
