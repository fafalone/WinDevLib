End Type

Public Enum DMusicPortParamsFeats
	DMUS_PORT_FEATURE_AUDIOPATH = &H00000001 /* Supports audiopath connection to DSound buffers. */
	DMUS_PORT_FEATURE_STREAMING = &H00000002 /* Supports streaming waves through the synth. */
End Enum

