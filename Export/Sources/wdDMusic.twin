/* Generic Sources */
Public Const CONN_SRC_NONE              = &H0000
Public Const CONN_SRC_LFO               = &H0001
Public Const CONN_SRC_KEYONVELOCITY     = &H0002
Public Const CONN_SRC_KEYNUMBER         = &H0003
Public Const CONN_SRC_EG1               = &H0004
Public Const CONN_SRC_EG2               = &H0005
Public Const CONN_SRC_PITCHWHEEL        = &H0006

/* Midi Controllers 0-127 */
