Public Const DMUS_VOLUME_MIN  = -20000 /* -200 dB */



'dmusici.h

' Public Alias TRANSITION_TYPE As Integer
' Public Alias MUSIC_TIME As Long

Public Const MT_MIN  = &H80000000 /* Minimum music time value. */
Public Const MT_MAX  = &H7FFFFFFF /* Maximum music time value. */
Public Const DMUS_PPQ  = 768 /* parts per quarter note */

Public Enum DMUS_STYLET_TYPES
	DMUS_STYLET_PATTERN = 0
	DMUS_STYLET_MOTIF = 1
End Enum

Public Enum DMUS_COMMANDT_TYPES
	DMUS_COMMANDT_GROOVE = 0
	DMUS_COMMANDT_FILL = 1
	DMUS_COMMANDT_INTRO = 2
	DMUS_COMMANDT_BREAK = 3
	DMUS_COMMANDT_END = 4
	DMUS_COMMANDT_ENDANDINTRO = 5
End Enum

Public Enum DMUS_SHAPET_TYPES
	DMUS_SHAPET_FALLING = 0
	DMUS_SHAPET_LEVEL = 1
	DMUS_SHAPET_LOOPABLE = 2
	DMUS_SHAPET_LOUD = 3
	DMUS_SHAPET_QUIET = 4
	DMUS_SHAPET_PEAKING = 5
	DMUS_SHAPET_RANDOM = 6
	DMUS_SHAPET_RISING = 7
	DMUS_SHAPET_SONG = 8
End Enum

Public Enum DMUS_COMPOSEF_FLAGS
	DMUS_COMPOSEF_NONE = 0
	DMUS_COMPOSEF_ALIGN = &H1
	DMUS_COMPOSEF_OVERLAP = &H2
	DMUS_COMPOSEF_IMMEDIATE = &H4
	DMUS_COMPOSEF_GRID = &H8
	DMUS_COMPOSEF_BEAT = &H10
	DMUS_COMPOSEF_MEASURE = &H20
	DMUS_COMPOSEF_AFTERPREPARETIME = &H40
	DMUS_COMPOSEF_VALID_START_BEAT = &H80 ' In conjunction with DMUS_COMPOSEF_ALIGN, allows the switch to occur on any beat. */
	DMUS_COMPOSEF_VALID_START_GRID = &H100 ' In conjunction with DMUS_COMPOSEF_ALIGN, allows the switch to occur on any grid. */
	DMUS_COMPOSEF_VALID_START_TICK = &H200 ' In conjunction with DMUS_COMPOSEF_ALIGN, allows the switch to occur any time. */
	DMUS_COMPOSEF_SEGMENTEND = &H400 ' Play the transition at the end of the current segment. */
	DMUS_COMPOSEF_MARKER = &H800 ' Play the transition at the next marker in the current segment. */
	DMUS_COMPOSEF_MODULATE = &H1000
	DMUS_COMPOSEF_LONG = &H2000
	DMUS_COMPOSEF_ENTIRE_TRANSITION = &H4000 ' play the entire transition pattern */
	DMUS_COMPOSEF_1BAR_TRANSITION = &H8000& ' play one bar of the transition pattern */
	DMUS_COMPOSEF_ENTIRE_ADDITION = &H10000 ' play the additional pattern in its entirety */
	DMUS_COMPOSEF_1BAR_ADDITION = &H20000 ' play one bar of the additional pattern */
	DMUS_COMPOSEF_VALID_START_MEASURE = &H40000 ' In conjunction with DMUS_COMPOSEF_ALIGN, allows the switch to occur on any bar. */
	DMUS_COMPOSEF_DEFAULT = &H80000 ' Use segment's default boundary */
	DMUS_COMPOSEF_NOINVALIDATE = &H100000 ' Play without invalidating the currently playing segment(s) */
	DMUS_COMPOSEF_USE_AUDIOPATH = &H200000 ' Uses the audio paths that are embedded in the segments */
	DMUS_COMPOSEF_INVALIDATE_PRI = &H400000 ' Invalidate only the current primary seg state */
End Enum

Public Type DMUS_PMSG
	dwSize As Long
    rtTime As REFERENCE_TIME '* real time (in 100 nanosecond increments) */          \
    mtTime As MUSIC_TIME '* music time */                                        \
    dwFlags As DMUS_PMSGF_FLAGS '* various bits (see DMUS_PMSGF_FLAGS enumeration) */    \
    dwPChannel As Long '* Performance Channel. The Performance can */          \
    '* use this to determine the port/channel. */           \
    dwVirtualTrackID As Long '* virtual track ID */                                  \
    pTool As IDirectMusicTool '* tool interface pointer */                            \
    pGraph As IDirectMusicGraph '* tool graph interface pointer */                      \
    dwType As Long '* PMSG type (see DMUS_PMSGT_TYPES defines) */              \
    dwVoiceID As Long '* unique voice id which allows synthesizers to */      \
    '* identify a specific event. For DirectX 6.0, */       \
    '* this field should always be 0. */                    \
    dwGroupID As Long '* Track group id */                                 \
    punkUser As IUnknown '* user com pointer, auto released upon PMSG free */
End Type

Public Enum DMusicPcBroadcast
	DMUS_PCHANNEL_BROADCAST_PERFORMANCE = &HFFFFFFFF /* PMsg is sent on all PChannels of the performance. */
	DMUS_PCHANNEL_BROADCAST_AUDIOPATH = &HFFFFFFFE /* PMsg is sent on all PChannels of the audio path. */
	DMUS_PCHANNEL_BROADCAST_SEGMENT = &HFFFFFFFD /* PMsg is sent on all PChannels of the segment. */
	DMUS_PCHANNEL_BROADCAST_GROUPS = &HFFFFFFFC /* A duplicate PMsg is for each Channels Groups in the performance. */
	DMUS_PCHANNEL_ALL = &HFFFFFFFB
End Enum

Public Enum DMusicPathConsts
	DMUS_PATH_SEGMENT = &H1000 /* Get the segment itself (from a segment state.) */
	DMUS_PATH_SEGMENT_TRACK = &H1100 /* Look in Track List of Segment. */
	DMUS_PATH_SEGMENT_GRAPH = &H1200 /* Get the segment's tool graph. */
	DMUS_PATH_SEGMENT_TOOL = &H1300 /* Look in Tool Graph of Segment. */
	DMUS_PATH_AUDIOPATH = &H2000 /* Get the audiopath itself (from a segment state.) */
	DMUS_PATH_AUDIOPATH_GRAPH = &H2200 /* Get the audiopath's tool graph. */
	DMUS_PATH_AUDIOPATH_TOOL = &H2300 /* Look in Tool Graph of Audio Path. */
	DMUS_PATH_PERFORMANCE = &H3000 /* Access the performance. */
	DMUS_PATH_PERFORMANCE_GRAPH = &H3200 /* Get the performance's tool graph. */
	DMUS_PATH_PERFORMANCE_TOOL = &H3300 /* Look in Tool Graph of Performance. */
	DMUS_PATH_PORT = &H4000 /* Access the synth. */
	DMUS_PATH_BUFFER = &H6000 /* Look in DirectSoundBuffer. */
	DMUS_PATH_BUFFER_DMO = &H6100 /* Access a DMO in the buffer. */
	DMUS_PATH_MIXIN_BUFFER = &H7000 /* Look in a global mixin buffer. */
	DMUS_PATH_MIXIN_BUFFER_DMO = &H7100 /* Access a DMO in a global mixin buffer. */
	DMUS_PATH_PRIMARY_BUFFER = &H8000& /* Access the primary buffer. */
End Enum

Public Enum DMusicAPathConsts
	DMUS_APATH_SHARED_STEREOPLUSREVERB = 1 /* A standard music set up with stereo outs and reverb. */
	DMUS_APATH_DYNAMIC_3D = 6 /* An audio path with one dynamic bus from the synth feeding to a dynamic 3d buffer. Does not send to env reverb. */
	DMUS_APATH_DYNAMIC_MONO = 7 /* An audio path with one dynamic bus from the synth feeding to a dynamic mono buffer. */
	DMUS_APATH_DYNAMIC_STEREO = 8 /* An audio path with two dynamic buses from the synth feeding to a dynamic stereo buffer. */
End Enum

Public Type DMUS_AUDIOPARAMS
	dwSize As Long '* Size of this structure. */
	fInitNow As BOOL '* If true, the sink and synth are created immediately and results returned in this structure. */
	dwValidData As DMusicAudioParamsValid '*/ Flags indicating which fields below are valid. */
	dwFeatures As DMusicAudioFeatures '*/ Required DMUS_AUDIOF features. */
	dwVoices As Long '*/ Required number of voices. */
	dwSampleRate As Long '* Sample rate of synths and sink. */
	clsidDefaultSynth As UUID '*/ Class ID of default synthesizer. */
End Type

Public Enum DMusicAudioFeatures
	DMUS_AUDIOF_3D = &H1  '* Require 3D buffers. */
	DMUS_AUDIOF_ENVIRON = &H2  '* Require environmental modeling. */
	DMUS_AUDIOF_EAX = &H4  '* Require use of EAX effects. */
	DMUS_AUDIOF_DMOS = &H8  '* Require use of additional DMOs. */
	DMUS_AUDIOF_STREAMING = &H10  '* Require support for streaming waves. */
	DMUS_AUDIOF_BUFFERS = &H20  '* Require support for multiple buffers (all above cases need this.) */
	DMUS_AUDIOF_ALL = &H3F  '* Requires everything. */
End Enum

Public Enum DMusicAudioParamsValid
	DMUS_AUDIOPARAMS_FEATURES = &H00000001
	DMUS_AUDIOPARAMS_VOICES = &H00000002
	DMUS_AUDIOPARAMS_SAMPLERATE = &H00000004
	DMUS_AUDIOPARAMS_DEFAULTSYNTH = &H00000008
End Enum

Public Enum DMUS_PMSGF_FLAGS
	DMUS_PMSGF_REFTIME = 1 ' if rtTime is valid */
	DMUS_PMSGF_MUSICTIME = 2 ' if mtTime is valid */
	DMUS_PMSGF_TOOL_IMMEDIATE = 4 ' if PMSG should be processed immediately */
	DMUS_PMSGF_TOOL_QUEUE = 8 ' if PMSG should be processed a little early, at Queue time */
	DMUS_PMSGF_TOOL_ATTIME = &H10 ' if PMSG should be processed at the time stamp */
	DMUS_PMSGF_TOOL_FLUSH = &H20 ' if PMSG is being flushed */
	DMUS_PMSGF_LOCKTOREFTIME = &H40 ' if rtTime can not be overriden by a tempo change. */
	DMUS_PMSGF_DX8 = &H80 ' if the message has DX8 or later extensions. */
End Enum

Public Enum DMUS_PMSGT_TYPES
	DMUS_PMSGT_MIDI = 0 ' MIDI short message */
	DMUS_PMSGT_NOTE = 1 ' Interactive Music Note */
	DMUS_PMSGT_SYSEX = 2 ' MIDI long message (system exclusive message) */
	DMUS_PMSGT_NOTIFICATION = 3 ' Notification message */
	DMUS_PMSGT_TEMPO = 4 ' Tempo message */
	DMUS_PMSGT_CURVE = 5 ' Control change / pitch bend, etc. curve */
	DMUS_PMSGT_TIMESIG = 6 ' Time signature */
	DMUS_PMSGT_PATCH = 7 ' Patch changes */
	DMUS_PMSGT_TRANSPOSE = 8 ' Transposition messages */
	DMUS_PMSGT_CHANNEL_PRIORITY = 9 ' Channel priority */
	DMUS_PMSGT_STOP = 10 ' Stop message */
	DMUS_PMSGT_DIRTY = 11 ' Tells Tools that cache GetParam() info to refresh */
	DMUS_PMSGT_WAVE = 12 ' Carries control information for playing a wave. */
	DMUS_PMSGT_LYRIC = 13 ' Lyric message from lyric track. */
	DMUS_PMSGT_SCRIPTLYRIC = 14 ' Lyric message sent by a script with the Trace function. */
	DMUS_PMSGT_USER = 255 ' User message */
End Enum

Public Enum DMUS_SEGF_FLAGS
	DMUS_SEGF_REFTIME = 1 << 6 ' 0x40 Time parameter is in reference time  */
	DMUS_SEGF_SECONDARY = 1 << 7 ' 0x80 Secondary segment */
	DMUS_SEGF_QUEUE = 1 << 8 ' 0x100 Queue at the end of the primary segment queue (primary only) */
	DMUS_SEGF_CONTROL = 1 << 9 ' 0x200 Play as a control track (secondary segments only) */
	DMUS_SEGF_AFTERPREPARETIME = 1 << 10 ' 0x400 Play after the prepare time (See IDirectMusicPerformance::GetPrepareTime) */
	DMUS_SEGF_GRID = 1 << 11 ' 0x800 Play on grid boundary */
	DMUS_SEGF_BEAT = 1 << 12 ' 0x1000 Play on beat boundary */
	DMUS_SEGF_MEASURE = 1 << 13 ' 0x2000 Play on measure boundary */
	DMUS_SEGF_DEFAULT = 1 << 14 ' 0x4000 Use segment's default boundary */
	DMUS_SEGF_NOINVALIDATE = 1 << 15& ' 0x8000 Play without invalidating the currently playing segment(s) */
	DMUS_SEGF_ALIGN = 1 << 16& ' 0x10000 Align segment with requested boundary, but switch at first valid point */
	DMUS_SEGF_VALID_START_BEAT = 1 << 17& ' 0x20000 In conjunction with DMUS_SEGF_ALIGN, allows the switch to occur on any beat. */
	DMUS_SEGF_VALID_START_GRID = 1 << 18& ' 0x40000 In conjunction with DMUS_SEGF_ALIGN, allows the switch to occur on any grid. */
	DMUS_SEGF_VALID_START_TICK = 1 << 19& ' 0x80000 In conjunction with DMUS_SEGF_ALIGN, allows the switch to occur any time. */
	DMUS_SEGF_AUTOTRANSITION = 1 << 20& ' 0x100000 Compose and play a transition segment, using the transition template. */
	DMUS_SEGF_AFTERQUEUETIME = 1 << 21& ' 0x200000 Make sure to play after the queue time. This is default for primary segments */
	DMUS_SEGF_AFTERLATENCYTIME = 1 << 22& ' 0x400000 Make sure to play after the latency time. This is true for all segments, so this is a nop */
	DMUS_SEGF_SEGMENTEND = 1 << 23& ' 0x800000 Play at the next end of segment. */
	DMUS_SEGF_MARKER = 1 << 24& ' 0x1000000 Play at next marker in the primary segment. If there are no markers, default to any other resolution requests. */
	DMUS_SEGF_TIMESIG_ALWAYS = 1 << 25& ' 0x2000000 Even if there is no primary segment, align start time with current time signature. */
	DMUS_SEGF_USE_AUDIOPATH = 1 << 26& ' 0x4000000 Uses the audio path that is embedded in the segment. */
	DMUS_SEGF_VALID_START_MEASURE = 1 << 27& ' 0x8000000 In conjunction with DMUS_SEGF_ALIGN, allows the switch to occur on any bar. */
	DMUS_SEGF_INVALIDATE_PRI = 1 << 28& ' 0x10000000 invalidate only the current primary seg state */
End Enum

Public Const DMUS_SEG_REPEAT_INFINITE  = &HFFFFFFFF /* For IDirectMusicSegment::SetRepeat*/
Public Const DMUS_SEG_ALLTRACKS  = &H80000000 /* For IDirectMusicSegment::SetParam() and SetTrackConfig() - selects all tracks instead on nth index. */
Public Const DMUS_SEG_ANYTRACK  = &H80000000 /* For IDirectMusicSegment::GetParam() - checks each track until it finds one that returns data (not DMUS_E_NOT_FOUND.) */

Public Enum DMUS_TIME_RESOLVE_FLAGS
	DMUS_TIME_RESOLVE_AFTERPREPARETIME = DMUS_SEGF_AFTERPREPARETIME
	DMUS_TIME_RESOLVE_AFTERQUEUETIME = DMUS_SEGF_AFTERQUEUETIME
	DMUS_TIME_RESOLVE_AFTERLATENCYTIME = DMUS_SEGF_AFTERLATENCYTIME
	DMUS_TIME_RESOLVE_GRID = DMUS_SEGF_GRID
	DMUS_TIME_RESOLVE_BEAT = DMUS_SEGF_BEAT
	DMUS_TIME_RESOLVE_MEASURE = DMUS_SEGF_MEASURE
	DMUS_TIME_RESOLVE_MARKER = DMUS_SEGF_MARKER
	DMUS_TIME_RESOLVE_SEGMENTEND = DMUS_SEGF_SEGMENTEND
End Enum

Public Enum DMUS_CHORDKEYF_FLAGS
DMUS_CHORDKEYF_SILENT = 1 ' is the chord silent? */
End Enum

Public Const DMUS_MAXSUBCHORD  = 8

Public Type DMUS_SUBCHORD
	dwChordPattern As Long '* Notes in the subchord */
	dwScalePattern As Long '* Notes in the scale */
	dwInversionPoints As Long '* Where inversions can occur */
	dwLevels As Long '* Which levels are supported by this subchord */
	bChordRoot As Byte '* Root of the subchord */
	bScaleRoot As Byte '* Root of the scale */
End Type

Public Type DMUS_CHORD_KEY
	wszName(0 To 15) As Integer '* Name of the chord */
	wMeasure As Integer '* Measure this falls on */
	bBeat As Byte '* Beat this falls on */
	bSubChordCount As Byte '* Number of chords in the list of subchords */
	SubChordList(0 To (DMUS_MAXSUBCHORD - 1)) As DMUS_SUBCHORD '* List of sub chords */
	dwScale As Long '* Scale underlying the entire chord */
	bKey As Byte '* Key underlying the entire chord */
	bFlags As Byte '* Miscelaneous flags */
End Type

Public Type DMUS_NOTE_PMSG
	dwSize As Long
	rtTime As REFERENCE_TIME '* real time (in 100 nanosecond increments) */           
	mtTime As MUSIC_TIME '* music time */                                         
	dwFlags As DMUS_PMSGF_FLAGS '* various bits (see DMUS_PMSGF_FLAGS enumeration) */     
	dwPChannel As Long '* Performance Channel. The Performance can */           
	'* use this to determine the port/channel. */
	dwVirtualTrackID As Long '* virtual track ID */                                   
	pTool As IDirectMusicTool '* tool interface pointer */                            
	pGraph As IDirectMusicGraph '* tool graph interface pointer */                      
	dwType As DMUS_PMSGT_TYPES '* PMSG type (see DMUS_PMSGT_TYPES defines) */              
	dwVoiceID As Long '* unique voice id which allows synthesizers to */       
	'* identify a specific event. For DirectX 6.0, */
	'* this field should always be 0. */
	dwGroupID As Long '* Track group id */                                 
	punkUser As IUnknown '* user com pointer, auto released upon PMSG free */
	mtDuration As MUSIC_TIME '* duration */
	wMusicValue As Integer '* Description of note in chord and key. */
	wMeasure As Integer '* Measure in which this note occurs */
	nOffset As Integer '* Offset from grid at which this note occurs */
	bBeat As Byte '* Beat (in measure) at which this note occurs */
	bGrid As Byte '* Grid offset from beat at which this note occurs */
	bVelocity As Byte '* Note velocity */
	bFlags As Byte '* see DMUS_NOTEF_FLAGS */
	bTimeRange As Byte '* Range to randomize time. */
	bDurRange As Byte '* Range to randomize duration. */
	bVelRange As Byte '* Range to randomize velocity. */
	bPlayModeFlags As Byte '* Play mode */
	bSubChordLevel As Byte '* Which subchord level this note uses.  */
	bMidiValue As Byte '* The MIDI note value, converted from wMusicValue */
	cTranspose As Byte '* Transposition to add to midi note value after converted from wMusicValue. */
End Type

Public Enum DMUS_NOTEF_FLAGS
	DMUS_NOTEF_NOTEON = 1 ' Set if this is a MIDI Note On. Otherwise, it is MIDI Note Off */
	DMUS_NOTEF_NOINVALIDATE = 2 ' Don't invalidate this note off. */
	DMUS_NOTEF_NOINVALIDATE_INSCALE = 4 ' Don't invalidate if still within the scale. */
	DMUS_NOTEF_NOINVALIDATE_INCHORD = 8 ' Don't invalidate if still within the chord. */
	DMUS_NOTEF_REGENERATE = &H10 ' Regenerate the note on an invalidate. */
End Enum

Public Enum DMUS_PLAYMODE_FLAGS
	DMUS_PLAYMODE_KEY_ROOT = 1 ' Transpose on top of the key root. */
	DMUS_PLAYMODE_CHORD_ROOT = 2 ' Transpose on top of the chord root. */
	DMUS_PLAYMODE_SCALE_INTERVALS = 4 ' Use scale intervals from scale pattern. */
	DMUS_PLAYMODE_CHORD_INTERVALS = 8 ' Use chord intervals from chord pattern. */
	DMUS_PLAYMODE_NONE = 16 ' No mode. Indicates the parent part's mode should be used. */
End Enum

Public Enum DMusicPlaybackModes
	/* Fixed. wMusicValue holds final MIDI note value. This is used for drums, sound effects, and sequenced
	notes that should not be transposed by the chord or scale.
	*/
	DMUS_PLAYMODE_FIXED = 0
	/* In fixed to key, the musicvalue is again a fixed MIDI value, but it
	is transposed on top of the key root. 
	*/
	DMUS_PLAYMODE_FIXEDTOKEY = DMUS_PLAYMODE_KEY_ROOT
	/* In fixed to chord, the musicvalue is also a fixed MIDI value, but it
	is transposed on top of the chord root. 
	*/
	DMUS_PLAYMODE_FIXEDTOCHORD = DMUS_PLAYMODE_CHORD_ROOT
	/* In Pedalpoint, the key root is used and the notes only track the intervals in
	the scale. The chord root and intervals are completely ignored. This is useful
	for melodic lines that play relative to the key root.
	*/
	DMUS_PLAYMODE_PEDALPOINT = (DMUS_PLAYMODE_KEY_ROOT Or DMUS_PLAYMODE_SCALE_INTERVALS)
	/* In the Melodic mode, the chord root is used but the notes only track the intervals in
	the scale. The key root and chord intervals are completely ignored. This is useful
	for melodic lines that play relative to the chord root. 
	*/
	DMUS_PLAYMODE_MELODIC = (DMUS_PLAYMODE_CHORD_ROOT Or DMUS_PLAYMODE_SCALE_INTERVALS)
	/* Normal chord mode is the prevalent playback mode. 
	The notes track the intervals in the chord, which is based on the chord root. 
	If there is a scale component to the MusicValue, the additional intervals 
	are pulled from the scale and added.
	If the chord does not have an interval to match the chord component of
	the MusicValue, the note is silent.
	*/
	DMUS_PLAYMODE_NORMALCHORD = (DMUS_PLAYMODE_CHORD_ROOT Or DMUS_PLAYMODE_CHORD_INTERVALS)
	/* If it is desirable to play a note that is above the top of the chord, the
	always play mode (known as "purpleized" in a former life) finds a position
	for the note by using intervals from the scale. Essentially, this mode is
	a combination of the Normal and Melodic playback modes, where a failure
	in Normal causes a second try in Melodic mode.
	*/
	DMUS_PLAYMODE_ALWAYSPLAY = (DMUS_PLAYMODE_MELODIC Or DMUS_PLAYMODE_NORMALCHORD)
	/* These playmodes are new for dx8. */
	/* In PedalpointChord, the key root is used and the notes only track the intervals in
	the chord. The chord root and scale intervals are completely ignored. This is useful
	for chordal lines that play relative to the key root.
	*/
	DMUS_PLAYMODE_PEDALPOINTCHORD = (DMUS_PLAYMODE_KEY_ROOT Or DMUS_PLAYMODE_CHORD_INTERVALS)
	/* For completeness, here's a mode that tries for pedalpointchord, but if it fails
	uses scale intervals
	*/
	DMUS_PLAYMODE_PEDALPOINTALWAYS = (DMUS_PLAYMODE_PEDALPOINT Or DMUS_PLAYMODE_PEDALPOINTCHORD)
	/*  Legacy names for modes... */
	DMUS_PLAYMODE_PURPLEIZED = DMUS_PLAYMODE_ALWAYSPLAY
	DMUS_PLAYMODE_SCALE_ROOT = DMUS_PLAYMODE_KEY_ROOT
	DMUS_PLAYMODE_FIXEDTOSCALE = DMUS_PLAYMODE_FIXEDTOKEY
End Enum

