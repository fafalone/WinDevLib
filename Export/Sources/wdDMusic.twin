Public Enum DMusicEffectsFlags
	DMUS_EFFECT_NONE = &H00000000
	DMUS_EFFECT_REVERB = &H00000001
	DMUS_EFFECT_CHORUS = &H00000002
	DMUS_EFFECT_DELAY = &H00000004
End Enum

Public Enum DMusicPortCapsClass
	DMUS_PC_INPUTCLASS = (0)
	DMUS_PC_OUTPUTCLASS = (1)
End Enum

Public Enum DMusicPortCapsFlags
	DMUS_PC_DLS = (&H00000001)  		  	' Supports DLS downloading and DLS level 1.
	DMUS_PC_EXTERNAL = (&H00000002)		  	' External MIDI module.
	DMUS_PC_SOFTWARESYNTH = (&H00000004)  	' Software synthesizer.
	DMUS_PC_MEMORYSIZEFIXED = (&H00000008)  ' Memory size is fixed.
	DMUS_PC_GMINHARDWARE = (&H00000010)  	' GM sound set is built in, no need to download.
	DMUS_PC_GSINHARDWARE = (&H00000020)  	' GS sound set is built in.
	DMUS_PC_XGINHARDWARE = (&H00000040)  	' XG sound set is built in.
	DMUS_PC_DIRECTSOUND = (&H00000080)  	' Connects to DirectSound via a DSound buffer.
	DMUS_PC_SHAREABLE = (&H00000100)  		' Synth can be actively shared by multiple apps at once.
	DMUS_PC_DLS2 = (&H00000200)  			' Supports DLS2 instruments.
	DMUS_PC_AUDIOPATH = (&H00000400)  		' Multiple outputs can be connected to DirectSound for audiopaths.
	DMUS_PC_WAVE = (&H00000800)  			' Supports streaming and one shot waves.
	DMUS_PC_SYSTEMMEMORY = (&H7FFFFFFF)  	' Sample memory is system memory.
End Enum

Public Type DMUS_PORTCAPS
	dwSize As Long
