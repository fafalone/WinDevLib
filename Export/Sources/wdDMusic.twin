*/
Public Const DMUS_E_INSUFFICIENTBUFFER       = &H88781104 'MAKE_DMHRESULTERROR(0x0104)

/* DMUS_E_BUFFERNOTSET
*
* No buffer was prepared for the download data.
*/
Public Const DMUS_E_BUFFERNOTSET             = &H88781105'MAKE_DMHRESULTERROR(0x0105)

/* DMUS_E_BUFFERNOTAVAILABLE
*
