Public Enum DMusicVariationFlags
	DMUS_VARIATIONF_MAJOR = &H0000007F /* Seven positions in the scale - major chords. */
	DMUS_VARIATIONF_MINOR = &H00003F80 /* Seven positions in the scale - minor chords. */
	DMUS_VARIATIONF_OTHER = &H001FC000 /* Seven positions in the scale - other chords. */
	DMUS_VARIATIONF_ROOT_SCALE = &H00200000 /* Handles chord roots in the scale. */
	DMUS_VARIATIONF_ROOT_FLAT = &H00400000 /* Handles flat chord roots (based on scale notes). */
	DMUS_VARIATIONF_ROOT_SHARP = &H00800000 /* Handles sharp chord roots (based on scale notes). */
	DMUS_VARIATIONF_TYPE_TRIAD = &H01000000 /* Handles simple chords - triads. */
	DMUS_VARIATIONF_TYPE_6AND7 = &H02000000 /* Handles simple chords - 6 and 7. */
	DMUS_VARIATIONF_TYPE_COMPLEX = &H04000000 /* Handles complex chords. */
	DMUS_VARIATIONF_DEST_TO1 = &H08000000 /* Handles transitions to 1 chord. */
	DMUS_VARIATIONF_DEST_TO5 = &H10000000 /* Handles transitions to 5 chord. */
	DMUS_VARIATIONF_DEST_OTHER = &H40000000 /* Handles transitions to chords other than 1 . */
	/* legacy mask for variation modes */
	DMUS_VARIATIONF_MODES = &HE0000000
    /* Bits 29 and 31 of the variation flags are the Mode bits.  If both are 0, it's IMA. */
    /* If bit 29 is 1, it's Direct Music. */
	DMUS_VARIATIONF_MODES_EX = (&H20000000 Or &H80000000)
	DMUS_VARIATIONF_IMA25_MODE = &H00000000
	DMUS_VARIATIONF_DMUS_MODE = &H20000000
End Enum

Public Enum DMusicPartFlags
	DMUS_PARTF_USE_MARKERS = &H1
	' * Set this if the part is allowed to switch only on chord-aligned markers */
	DMUS_PARTF_ALIGN_CHORDS = &H2
End Enum

Public Enum DMusicMarkerFlags
	DMUS_MARKERF_START = &H1
	DMUS_MARKERF_STOP = &H2
	DMUS_MARKERF_CHORD_ALIGN = &H4
End Enum

Public Enum DMusicPatternFlags
	DMUS_PATTERNF_PERSIST_CONTROL = &H1
End Enum

Public Enum enumDMUS_VARIATIONT_TYPES
	DMUS_VARIATIONT_SEQUENTIAL = 0 ' Play sequential starting with variation 1. */
	DMUS_VARIATIONT_RANDOM = 1 ' Play randomly. */
	DMUS_VARIATIONT_RANDOM_START = 2 ' Play sequential starting with a random variation. */
	DMUS_VARIATIONT_NO_REPEAT = 3 ' Play randomly, but don't play the same variation twice. */
	DMUS_VARIATIONT_RANDOM_ROW = 4 ' Play randomly as a row: don't repeat any variation until all have played. */
End Enum

Public Enum enumDMUS_EMBELLISHT_TYPES
	DMUS_EMBELLISHT_NORMAL = 0
	DMUS_EMBELLISHT_FILL = 1
	DMUS_EMBELLISHT_BREAK = 2
	DMUS_EMBELLISHT_INTRO = 4
	DMUS_EMBELLISHT_END = 8
	DMUS_EMBELLISHT_MOTIF = 16
	DMUS_EMBELLISHT_ALL = &HFFFF&
End Enum

[PackingAlignment(2)]
Public Type DMUS_IO_TIMESIG
	'* Time signatures define how many beats per measure, which note receives */
	'* the beat, and the grid resolution. */
	bBeatsPerMeasure As Byte '* beats per measure (top of time sig) */
	bBeat As Byte '* what note receives the beat (bottom of time sig.) */
	'* we can assume that 0 means 256th note */
	wGridsPerBeat As Integer '* grids per beat */
End Type

[PackingAlignment(2)]
Public Type DMUS_IO_STYLE
	timeSig As DMUS_IO_TIMESIG '* Styles have a default Time Signature */
	dblTempo As Double
End Type

[PackingAlignment(2)]
Public Type DMUS_IO_VERSION
	dwVersionMS As Long '* Version # high-order 32 bits */
	dwVersionLS As Long '* Version # low-order 32 bits  */
End Type

[PackingAlignment(2)]
Public Type DMUS_IO_PATTERN
	timeSig As DMUS_IO_TIMESIG '/* Patterns can override the Style's Time sig. */
	bGrooveBottom As Byte '* bottom of groove range */
	bGrooveTop As Byte '* top of groove range */
	wEmbellishment As Integer '* Fill, Break, Intro, End, Normal, Motif */
	wNbrMeasures As Integer '* length in measures */
	bDestGrooveBottom As Byte '* bottom of groove range for next pattern */
	bDestGrooveTop As Byte '* top of groove range for next pattern */
	dwFlags As Long '* various flags */
End Type

[PackingAlignment(2)]
Public Type DMUS_IO_STYLEPART
	timeSig As DMUS_IO_TIMESIG '* can override pattern's */
	dwVariationChoices(0 To 31) As Long '* MOAW choice bitfield */
	guidPartID As UUID '* identifies the part */
	wNbrMeasures As Integer '* length of the Part */
	bPlayModeFlags As Byte '* see PLAYMODE flags */
	bInvertUpper As Byte '* inversion upper limit */
	bInvertLower As Byte '* inversion lower limit */
	bPad(0 To 2) As Byte '* for DWORD alignment */
	dwFlags As Long '* various flags */
End Type

[PackingAlignment(2)]
Public Type DMUS_IO_PARTREF
	guidPartID As UUID '* unique ID for matching up with parts */
	wLogicalPartID As Integer '* corresponds to port/device/midi channel OBSOLETE */
	bVariationLockID As Byte '* parts with the same ID lock variations. */
	'* high bit is used to identify master Part */
	bSubChordLevel As Byte '* tells which sub chord level this part wants */
	bPriority As Byte '* 256 priority levels. Parts with lower priority */
	'* aren't played first when a device runs out of */
	'* notes */
	bRandomVariation As Byte '* when set, matching variations play in random order */
	'* when clear, matching variations play sequentially */
	wPad As Integer '* not used */
	dwPChannel As Long '* replaces wLogicalPartID */
End Type

[PackingAlignment(2)]
Public Type DMUS_IO_STYLENOTE
	mtGridStart As MUSIC_TIME '* when this note occurs */
	dwVariation As Long '* variation bits */
	mtDuration As MUSIC_TIME '* how long this note lasts */
	nTimeOffset As Integer '* offset from mtGridStart */
	wMusicValue As Integer '* Position in scale. */
	bVelocity As Byte '* Note velocity. */
	bTimeRange As Byte '* Range to randomize start time. */
	bDurRange As Byte '* Range to randomize duration. */
	bVelRange As Byte '* Range to randomize velocity. */
	bInversionID As Byte '* Identifies inversion group to which this note belongs */
	bPlayModeFlags As Byte '* Can override part */
	'* Following exists only under DX8 and on */
	bNoteFlags As Byte '* values from DMUS_NOTEF_FLAGS */
End Type

[PackingAlignment(2)]
Public Type DMUS_IO_STYLECURVE
	mtGridStart As MUSIC_TIME '* when this curve occurs */
	dwVariation As Long '* variation bits */
	mtDuration As MUSIC_TIME '* how long this curve lasts */
	mtResetDuration As MUSIC_TIME '* how long after the end of the curve to reset the curve */
	nTimeOffset As Integer '* offset from mtGridStart */
	nStartValue As Integer '* curve's start value */
	nEndValue As Integer '* curve's end value */
	nResetValue As Integer '* the value to which to reset the curve */
	bEventType As Byte '* type of curve */
	bCurveShape As Byte '* shape of curve */
	bCCData As Byte '* CC# */
	bFlags As Byte '* Bit 1=TRUE means to send nResetValue. Otherwise, don't.
	'   Other bits are reserved. */
	'*  Following was added for DX8. */
	wParamType As Integer '* RPN or NRPN parameter number. */
	wMergeIndex As Integer '* Allows multiple parameters to be merged (pitchbend, volume, and expression.) */
End Type

[PackingAlignment(2)]
Public Type DMUS_IO_STYLEMARKER
	mtGridStart As MUSIC_TIME '* when this marker occurs */
	dwVariation As Long '* variation bits */
	wMarkerFlags As Integer '* how the marker is used */
End Type

[PackingAlignment(2)]
Public Type DMUS_IO_STYLERESOLUTION
	dwVariation As Long '* variation bits */
	wMusicValue As Integer '* Position in scale. */
	bInversionID As Byte '* Identifies inversion group to which this note belongs */
	bPlayModeFlags As Byte '* Can override part */
End Type

[PackingAlignment(2)]
Public Type DMUS_IO_STYLE_ANTICIPATION
	mtGridStart As MUSIC_TIME '* when this anticipation occurs */
	dwVariation As Long '* variation bits */
	nTimeOffset As Integer '* offset from mtGridStart */
	bTimeRange As Byte '* Range to randomize start time. */
End Type

[PackingAlignment(2)]
Public Type DMUS_IO_MOTIFSETTINGS
	dwRepeats As Long '* Number of repeats. By default, 0. */
	mtPlayStart As MUSIC_TIME '* Start of playback. By default, 0. */
	mtLoopStart As MUSIC_TIME '* Start of looping portion. By default, 0. */
	mtLoopEnd As MUSIC_TIME '* End of loop. Must be greater than mtLoopStart. Or, 0, indicating loop full motif.  */
	dwResolution As Long '* Default resolution. */
End Type

Public Const DMUS_FOURCC_PATTERN_FORM = &H54504d44 ' mmioFOURCC('D','M','P','T')
                            
Public Enum enumDMUS_PATTERNT_TYPES
	DMUS_PATTERNT_RANDOM = 0 '* Play randomly. (dx7 behavior) */
	DMUS_PATTERNT_REPEAT = 1 '* Repeat last pattern. */
	DMUS_PATTERNT_SEQUENTIAL = 2 '* Play sequential starting with first matching pattern. */
	DMUS_PATTERNT_RANDOM_START = 3 ' Play sequential starting with a random pattern. */
	DMUS_PATTERNT_NO_REPEAT = 4 '* Play randomly, but don't play the same pattern twice. */
	DMUS_PATTERNT_RANDOM_ROW = 5 '* Play randomly as a row: don't repeat any pattern until all have played. */
End Enum

