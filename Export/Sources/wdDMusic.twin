	rtReadAhead As REFERENCE_TIME '* How far ahead in the stream wave data will be read (in REFERENCE_TIME).  Ignored for one-shot waves.  */
	dwFlags As Long '* Various flags, including whether this is a streaming wave and whether it can be invalidated. */
End Type

Public Const DMUS_FOURCC_WAVETRACK_LIST = &H74766177
Public Const DMUS_FOURCC_WAVEPART_LIST = &H70766177
Public Const DMUS_FOURCC_WAVEPART_CHUNK = &H68706177
