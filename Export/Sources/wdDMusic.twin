*/
Public Const DMUS_E_AUDIOVBSCRIPT_SYNTAXERROR     = &H88781223 'MAKE_DMHRESULTERROR(0x0223)

/* DMUS_E_AUDIOVBSCRIPT_RUNTIMEERROR
*
* A script routine written in AudioVBScript failed because an invalid operation occurred.  For example,
* adding the number 3 to a segment object would produce this error.  So would attempting to call a routine
* that doesn't exist.
*/
Public Const DMUS_E_AUDIOVBSCRIPT_RUNTIMEERROR     = &H88781224 'MAKE_DMHRESULTERROR(0x0224)

/* DMUS_E_AUDIOVBSCRIPT_OPERATIONFAILURE
*
* A script routine written in AudioVBScript failed because a function outside of a script failed to complete.
* For example, a call to PlaySegment that fails to play because of low memory would return this error.
*/
Public Const DMUS_E_AUDIOVBSCRIPT_OPERATIONFAILURE     = &H88781225 'MAKE_DMHRESULTERROR(0x0225)

/* DMUS_E_AUDIOPATHS_NOT_VALID
*
* The Performance has set up some PChannels using the AssignPChannel command, which 
* makes it not capable of supporting audio paths.
*/
Public Const DMUS_E_AUDIOPATHS_NOT_VALID     = &H88781226 'MAKE_DMHRESULTERROR(0x0226)

/* DMUS_E_AUDIOPATHS_IN_USE
*
* This is the inverse of the previous error. 
* The Performance has set up some audio paths, which makes is incompatible
* with the calls to allocate pchannels, etc. 
*/
Public Const DMUS_E_AUDIOPATHS_IN_USE     = &H88781227 'MAKE_DMHRESULTERROR(0x0227)

/* DMUS_E_NO_AUDIOPATH_CONFIG
*
* A segment was asked for its embedded audio path configuration,
* but there isn't any. 
*/
Public Const DMUS_E_NO_AUDIOPATH_CONFIG     = &H88781228 'MAKE_DMHRESULTERROR(0x0228)

/* DMUS_E_AUDIOPATH_INACTIVE
*
* An audiopath is inactive, perhaps because closedown was called.
*/
Public Const DMUS_E_AUDIOPATH_INACTIVE     = &H88781229 'MAKE_DMHRESULTERROR(0x0229)

/* DMUS_E_AUDIOPATH_NOBUFFER
*
* An audiopath failed to create because a requested buffer could not be created.
*/
Public Const DMUS_E_AUDIOPATH_NOBUFFER     = &H8878122a 'MAKE_DMHRESULTERROR(0x022A)

/* DMUS_E_AUDIOPATH_NOPORT
*
* An audiopath could not be used for playback because it lacked port assignments.
*/
Public Const DMUS_E_AUDIOPATH_NOPORT     = &H8878122b 'MAKE_DMHRESULTERROR(0x022B)

/* DMUS_E_NO_AUDIOPATH
*
* Attempt was made to play segment in audiopath mode and there was no audiopath.
*/
Public Const DMUS_E_NO_AUDIOPATH     = &H8878122c 'MAKE_DMHRESULTERROR(0x022C)

/* DMUS_E_INVALIDCHUNK
*
* Invalid data was found in a RIFF file chunk.
*/
Public Const DMUS_E_INVALIDCHUNK     = &H8878122d 'MAKE_DMHRESULTERROR(0x022D)

/* DMUS_E_AUDIOPATH_NOGLOBALFXBUFFER
*
* Attempt was made to create an audiopath that sends to a global effects buffer which did not exist.
*/
Public Const DMUS_E_AUDIOPATH_NOGLOBALFXBUFFER     = &H8878122e 'MAKE_DMHRESULTERROR(0x022E)

/* DMUS_E_INVALID_CONTAINER_OBJECT
*
* The file does not contain a valid container object.
*/
Public Const DMUS_E_INVALID_CONTAINER_OBJECT    = &H8878122f 'MAKE_DMHRESULTERROR(0x022F)

    
    
'dmdls.h

Public Type DMUS_DOWNLOADINFO
	dwDLType As Long '* Instrument or Wave */
	dwDLId As Long '* Unique identifier to tag this download. */
	dwNumOffsetTableEntries As Long '* Number of index in the offset address table. */
	cbSize As Long '* Total size of this memory chunk. */
End Type

Public Const DMUS_DOWNLOADINFO_INSTRUMENT  = 1
Public Const DMUS_DOWNLOADINFO_WAVE  = 2
Public Const DMUS_DOWNLOADINFO_INSTRUMENT2  = 3 /* New version for better DLS2 support. */
' /* Support for oneshot and streaming wave data
'  */
Public Const DMUS_DOWNLOADINFO_WAVEARTICULATION  = 4 /* Wave articulation data */
Public Const DMUS_DOWNLOADINFO_STREAMINGWAVE  = 5 /* One chunk of a streaming */
Public Const DMUS_DOWNLOADINFO_ONESHOTWAVE  = 6
Public Const DMUS_DEFAULT_SIZE_OFFSETTABLE  = 1
/* Flags for DMUS_INSTRUMENT's ulFlags member */
Public Const DMUS_INSTRUMENT_GM_INSTRUMENT  = (1 << 0)

Public Type DMUS_OFFSETTABLE
	ulOffsetTable(0 To (DMUS_DEFAULT_SIZE_OFFSETTABLE - 1)) As Long
End Type

Public Type DMUS_INSTRUMENT
	ulPatch As Long
	ulFirstRegionIdx As Long
	ulGlobalArtIdx As Long '* If zero the instrument does not have an articulation */
	ulFirstExtCkIdx As Long '* If zero no 3rd party entenstion chunks associated with the instrument */
	ulCopyrightIdx As Long '* If zero no Copyright information associated with the instrument */
	ulFlags As Long
End Type

Public Type DMUS_REGION
	RangeKey As RGNRANGE
	RangeVelocity As RGNRANGE
	fusOptions As Integer
	usKeyGroup As Integer
	ulRegionArtIdx As Long '* If zero the region does not have an articulation */
	ulNextRegionIdx As Long '* If zero no more regions */
	ulFirstExtCkIdx As Long '* If zero no 3rd party entenstion chunks associated with the region */
	WaveLink As WAVELINK
	WSMP As WSMPL '/*  If WSMP.cSampleLoops > 1 then a WLOOP is included */
	WLOOP(0 To 0) As WLOOP
End Type

Public Type DMUS_LFOPARAMS
	pcFrequency As Long 'PCENT
	tcDelay As Long 'TCENT
	gcVolumeScale As Long 'GCENT
	pcPitchScale As Long 'PCENT
	gcMWToVolume As Long 'GCENT
	pcMWToPitch As Long 'PCENT
End Type

Public Type DMUS_VEGPARAMS
	tcAttack As Long 'TCENT
	tcDecay As Long 'TCENT
	ptSustain As Long 'PERCENT
	tcRelease As Long 'TCENT
	tcVel2Attack As Long 'TCENT
	tcKey2Decay As Long 'TCENT
End Type

Public Type DMUS_PEGPARAMS
	tcAttack As Long 'TCENT
	tcDecay As Long 'TCENT
	ptSustain As Long 'PERCENT
	tcRelease As Long 'TCENT
	tcVel2Attack As Long 'TCENT
	tcKey2Decay As Long 'TCENT
	pcRange As Long 'PCENT
End Type

Public Type DMUS_MSCPARAMS
	ptDefaultPan As Long 'PERCENT
End Type

Public Type DMUS_ARTICPARAMS
	LFO As DMUS_LFOPARAMS
	VolEG As DMUS_VEGPARAMS
	PitchEG As DMUS_PEGPARAMS
	Misc As DMUS_MSCPARAMS
End Type

Public Type DMUS_ARTICULATION
	ulArt1Idx As Long '* DLS Level 1 articulation chunk */
	ulFirstExtCkIdx As Long '* 3rd party extenstion chunks associated with the articulation */
End Type

Public Type DMUS_ARTICULATION2
	ulArtIdx As Long '* DLS Level 1/2 articulation chunk */
	ulFirstExtCkIdx As Long '* 3rd party extenstion chunks associated with the articulation */
	ulNextArtIdx As Long '* Additional articulation chunks */
End Type

Public Const DMUS_MIN_DATA_SIZE  = 4

Public Type DMUS_EXTENSIONCHUNK
	cbSize As Long '*  Size of extension chunk  */
	ulNextExtCkIdx As Long '*  If zero no more 3rd party entenstion chunks */
	ExtCkID As Long 'FOURCC
	byExtCk(0 To (DMUS_MIN_DATA_SIZE - 1)) As Byte '*  The actual number that follows is determined by cbSize */
End Type

Public Type DMUS_COPYRIGHT
	cbSize As Long '*  Size of copyright information */
	byCopyright(0 To (DMUS_MIN_DATA_SIZE - 1)) As Byte '*  The actual number that follows is determined by cbSize */
End Type

Public Type DMUS_WAVEDATA
	cbSize As Long
	byData(0 To (DMUS_MIN_DATA_SIZE - 1)) As Byte
End Type

Public Type DMUS_WAVE
	ulFirstExtCkIdx As Long '* If zero no 3rd party entenstion chunks associated with the wave */
	ulCopyrightIdx As Long '* If zero no Copyright information associated with the wave */
	ulWaveDataIdx As Long '* Location of actual wave data. */
	WaveformatEx As WAVEFORMATEX
End Type

Public Type DMUS_NOTERANGE
	dwLowNote As Long '* Sets the low note for the range of MIDI note events to which the instrument responds.*/
	dwHighNote As Long '* Sets the high note for the range of MIDI note events to which the instrument responds.*/
End Type

Public Type DMUS_WAVEARTDL
	ulDownloadIdIdx As Long '* Download ID's of each buffer */
	ulBus As Long '* Playback bus */
	ulBuffers As Long '* Buffers */
	ulMasterDLId As Long '* Download ID of master voice of slave group */
	usOptions As Integer '* Same as DLS2 region options */
End Type

Public Type DMUS_WAVEDL
	cbWaveData As Long '* Bytes of wave data */
End Type



'dmusbuff.h

[PackingAlignment(4)]
Public Type DMUS_EVENTHEADER
	cbEvent As Long '* Unrounded bytes in event */
	dwChannelGroup As Long '* Channel group of event */
	rtDelta As REFERENCE_TIME '* Delta from start time of entire buffer */
	dwFlags As Long '* Flags DMUS_EVENT_xxx */
End Type

Public Const DMUS_EVENT_STRUCTURED  = &H00000001 /* Unstructured data (SysEx, etc.) */

Private Function QWORD_ALIGN(ByVal x As Long) As Long
    QWORD_ALIGN = (x + 7) And Not 7
End Function

Public Function DMUS_EVENT_SIZE(ByVal cb As Long) As Long
    Return QWORD_ALIGN(LenB(Of DMUS_EVENTHEADER) + cb)
End Function



'dmusicc.h

Public Const DMUS_MAX_DESCRIPTION  = 128
