Public Enum DMusicIoScriptTrackTimingFlags
	DMUS_IO_SCRIPTTRACKF_PREPARE = (1 << 0) /* Fire event in advance of time stamp, at Prepare time. This is the default because it leaves the script time to change the music happening at the target time. */
	DMUS_IO_SCRIPTTRACKF_QUEUE = (1 << 1) /* Fire event just before time stamp, at Queue time. */
	DMUS_IO_SCRIPTTRACKF_ATTIME = (1 << 2) /* Fire event right at the time stamp. */
End Enum

