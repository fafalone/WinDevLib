	dwSize As Long '* Size in bytes of the structure */
	dwValidStats As Long '* Flags indicating which fields below are valid. */
	dwVoices As Long '* Average number of voices playing. */
	dwTotalCPU As Long '* Total CPU usage as percent * 100. */
	dwCPUPerVoice As Long '* CPU per voice as percent * 100. */
	dwLostNotes As Long ' Number of notes lost in 1 second. */
	dwFreeMemory As Long '* Free memory in bytes */
	lPeakVolume As Long '* Decibel level * 100. */
End Type

Public Type DMUS_SYNTHSTATS8
	dwSize As Long '* Size in bytes of the structure */
	dwValidStats As DMusicSynthStatsValid '* Flags indicating which fields below are valid. */
	dwVoices As Long '* Average number of voices playing. */
	dwTotalCPU As Long '* Total CPU usage as percent * 100. */
	dwCPUPerVoice As Long '* CPU per voice as percent * 100. */
	dwLostNotes As Long '* Number of notes lost in 1 second. */
	dwFreeMemory As Long '* Free memory in bytes */
	lPeakVolume As Long '* Decibel level * 100. */
	dwSynthMemUse As Long '* Memory used by synth wave data */ 
End Type

Public Enum DMusicSynthStatsValid
	DMUS_SYNTHSTATS_VOICES = (1 << 0)
	DMUS_SYNTHSTATS_TOTAL_CPU = (1 << 1)
	DMUS_SYNTHSTATS_CPU_PER_VOICE = (1 << 2)
	DMUS_SYNTHSTATS_LOST_NOTES = (1 << 3)
	DMUS_SYNTHSTATS_PEAK_VOLUME = (1 << 4)
	DMUS_SYNTHSTATS_FREE_MEMORY = (1 << 5)
	DMUS_SYNTHSTATS_SYSTEMMEMORY = DMUS_PC_SYSTEMMEMORY
End Enum

Public Type DMUS_WAVES_REVERB_PARAMS
	fInGain As Single '* Input gain in dB (to avoid output overflows) */
	fReverbMix As Single /* Reverb mix in dB. 0dB means 100% wet reverb (no direct signal)
                                Negative values gives less wet signal.
                                The coeficients are calculated so that the overall output level stays 
                                (approximately) constant regardless of the ammount of reverb mix. */
	fReverbTime As Single '* The reverb decay time, in milliseconds. */
	fHighFreqRTRatio As Single /* The ratio of the high frequencies to the global reverb time. 
                                Unless very 'splashy-bright' reverbs are wanted, this should be set to 
                                a value < 1.0.
                                For example if dRevTime==1000ms and dHighFreqRTRatio=0.1 than the 
                                decay time for high frequencies will be 100ms.*/
End Type

/*  Note: Default values for Reverb are:
fInGain             = 0.0dB   (no change in level)
fReverbMix          = -10.0dB   (a reasonable reverb mix)
fReverbTime         = 1000.0ms (one second global reverb time)
fHighFreqRTRatio    = 0.001    (the ratio of the high frequencies to the global reverb time) 
*/

Public Enum DMUS_CLOCKTYPE
	DMUS_CLOCK_SYSTEM = 0
	DMUS_CLOCK_WAVE = 1
End Enum


Public Const DMUS_CLOCKF_GLOBAL  = &H00000001

