Public Function IID_IDirectMusicSynth() As UUID
Static iid As UUID
 If (iid.Data1 = 0) Then Call DEFINE_UUID(iid, &H9823661, &H5c85, &H11d2, &Haf, &Ha6, &H0, &Haa, &H0, &H24, &Hd8, &Hb6)
IID_IDirectMusicSynth = iid
End Function
Public Function IID_IDirectMusicSynth8() As UUID
Static iid As UUID
 If (iid.Data1 = 0) Then Call DEFINE_UUID(iid, &H53cab625, &H2711, &H4c9f, &H9d, &He7, &H1b, &H7f, &H92, &H5f, &H6f, &Hc8)
IID_IDirectMusicSynth8 = iid
End Function
Public Function IID_IDirectMusicSynthSink() As UUID
Static iid As UUID
 If (iid.Data1 = 0) Then Call DEFINE_UUID(iid, &H9823663, &H5c85, &H11d2, &Haf, &Ha6, &H0, &Haa, &H0, &H24, &Hd8, &Hb6)
IID_IDirectMusicSynthSink = iid
End Function
Public Function GUID_DMUS_PROP_SetSynthSink() As UUID
Static iid As UUID
 If (iid.Data1 = 0) Then Call DEFINE_UUID(GUID_DMUS_PROP_SetSynthSink, &H0a3a5ba5, &H37b6, &H11d2, &Hb9, &Hf9, &H00, &H00, &Hf8, &H75, &Hac, &H12)
GUID_DMUS_PROP_SetSynthSink = iid
End Function
Public Function GUID_DMUS_PROP_SinkUsesDSound() As UUID
Static iid As UUID
 If (iid.Data1 = 0) Then Call DEFINE_UUID(iid, &Hbe208857, &H8952, &H11d2, &Hba, &H1c, &H00, &H00, &Hf8, &H75, &Hac, &H12)
GUID_DMUS_PROP_SinkUsesDSound = iid
End Function


