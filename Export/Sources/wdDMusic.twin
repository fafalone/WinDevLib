Public Function DLSID_GMInHardware() As UUID
Static iid As UUID
 If (iid.Data1 = 0) Then Call DEFINE_UUID(iid, &H178f2f24, &Hc364, &H11d1, &Ha7, &H60, &H00, &H00, &Hf8, &H75, &Hac, &H12)
DLSID_GMInHardware = iid
End Function
