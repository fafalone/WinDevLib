Public Const CONN_TRN_NONE              = &H0000
Public Const CONN_TRN_CONCAVE           = &H0001

Public Type DLSID
	ulData1 As Long
	usData2 As Integer
	usData3 As Integer
	abData4(0 To 7) As Byte
End Type

Public Type DLSVERSION
	dwVersionMS As Long
	dwVersionLS As Long
End Type

Public Type CONNECTION
	usSource As Integer
	usControl As Integer
	usDestination As Integer
	usTransform As Integer
	lScale As Long
End Type

Public Type CONNECTIONLIST
	cbSize As Long '* size of the connection list structure */
	cConnections As Long '* count of connections in the list */
End Type

Public Type RGNRANGE
	usLow As Integer
	usHigh As Integer
End Type

Public Const F_INSTRUMENT_DRUMS  = &H80000000

Public Type MIDILOCALE
	ulBank As Long
	ulInstrument As Long
End Type

Public Const F_RGN_OPTION_SELFNONEXCLUSIVE  = &H0001

Public Type RGNHEADER
	RangeKey As RGNRANGE '* Key range  */
	RangeVelocity As RGNRANGE '* Velocity Range  */
	fusOptions As Integer '* Synthesis options for this range */
	usKeyGroup As Integer '* Key grouping for non simultaneous play */
	'* 0 = no group, 1 up is group */
	'* for Level 1 only groups 1-15 are allowed */
End Type

Public Type INSTHEADER
	cRegions As Long '* Count of regions in this instrument */
	Locale As MIDILOCALE '* Intended MIDI locale of this instrument */
End Type

Public Type DLSHEADER
	cInstruments As Long      ' Count of instruments in the collection
End Type

Public Const WAVELINK_CHANNEL_LEFT  = &H0001
Public Const WAVELINK_CHANNEL_RIGHT  = &H0002
Public Const F_WAVELINK_PHASE_MASTER  = &H0001

Public Type WAVELINK
	fusOptions As Integer '* options flags for this wave */
	usPhaseGroup As Integer '* Phase grouping for locking channels */
	ulChannel As Long '* channel placement */
	ulTableIndex As Long '* index into the wave pool table, 0 based */
End Type

Public Const POOL_CUE_NULL  = &Hffffffff

Public Type POOLCUE
	ulOffset As Long ' Offset to the entry in the list */
End Type

Public Type POOLTABLE
	cbSize As Long '* size of the pool table structure */
	cCues As Long '* count of cues in the list */
End Type

Public Const F_WSMP_NO_TRUNCATION  = &H0001
Public Const F_WSMP_NO_COMPRESSION  = &H0002

Public Type WSMPL
	cbSize As Long
	usUnityNote As Integer '* MIDI Unity Playback Note */
	sFineTune As Integer '* Fine Tune in log tuning */
	lAttenuation As Long ' Overall Attenuation to be applied to data */
	fulOptions As Long ' Flag options  */
	cSampleLoops As Long '/ Count of Sample loops, 0 loops is one shot */
End Type

Public Const WLOOP_TYPE_FORWARD  = 0

Public Type WLOOP
	cbSize As Long
	ulType As Long '* Loop Type */
	ulStart As Long '* Start of loop in samples */
	ulLength As Long '* Length of loop in samples */
End Type

'dmerror.h

Public Const DMUS_ERRBASE  = &H1000 /* Make error codes human readable in hex */

Public Function MAKE_DMHRESULTSUCCESS(ByVal code As Long) As Long
    MAKE_DMHRESULTSUCCESS = MAKE_HRESULT(0, FACILITY_DIRECTMUSIC, DMUS_ERRBASE + code)
End Function

Public Function MAKE_DMHRESULTERROR(ByVal code As Long) As Long
    MAKE_DMHRESULTERROR = MAKE_HRESULT(1, FACILITY_DIRECTMUSIC, DMUS_ERRBASE + code)
End Function

/* DMUS_S_PARTIALLOAD
*
* The object could only load partially. This can happen if some components are
* not registered properly, such as embedded tracks and tools. This can also happen
* if some content is missing. For example, if a segment uses a DLS collection that
* is not in the loader's current search directory.
*/
Public Const DMUS_S_PARTIALLOAD  = &H8781091 'MAKE_DMHRESULTSUCCESS(&H091)
/* DMUS_S_PARTIALDOWNLOAD
 *
 * Return value from IDirectMusicBand::Download() which indicates that
 * some of the instruments safely downloaded, but others failed. This usually
 * occurs when some instruments are on PChannels not supported by the performance
 * or port.
 */
Public Const DMUS_S_PARTIALDOWNLOAD          = &H8781092 'MAKE_DMHRESULTSUCCESS(0x092)

/* DMUS_S_REQUEUE
 *
 * Return value from IDirectMusicTool::ProcessPMsg() which indicates to the
 * performance that it should cue the PMsg again automatically.
 */
Public Const DMUS_S_REQUEUE                  = &H8781200 'MAKE_DMHRESULTSUCCESS(0x200)

/* DMUS_S_FREE
 *
 * Return value from IDirectMusicTool::ProcessPMsg() which indicates to the
 * performance that it should free the PMsg automatically.
 */
Public Const DMUS_S_FREE                     = &H8781201 'MAKE_DMHRESULTSUCCESS(0x201)

/* DMUS_S_END
 *
 * Return value from IDirectMusicTrack::Play() which indicates to the
 * segment that the track has no more data after mtEnd.
 */
Public Const DMUS_S_END                      = &H8781202 'MAKE_DMHRESULTSUCCESS(0x202)

/* DMUS_S_STRING_TRUNCATED
 *
 * Returned string has been truncated to fit the buffer size.
 */
Public Const DMUS_S_STRING_TRUNCATED         = &H8781210 'MAKE_DMHRESULTSUCCESS(0x210)

/* DMUS_S_LAST_TOOL
 *
 * Returned from IDirectMusicGraph::StampPMsg(), this indicates that the PMsg
 * is already stamped with the last tool in the graph. The returned PMsg's
 * tool pointer is now NULL.
 */
Public Const DMUS_S_LAST_TOOL                = &H8781211 'MAKE_DMHRESULTSUCCESS(0x211)

/* DMUS_S_OVER_CHORD
 *
 * Returned from IDirectMusicPerformance::MusicToMIDI(), this indicates 
 * that no note has been calculated because the music value has the note 
 * at a position higher than the top note of the chord. This applies only
 * to DMUS_PLAYMODE_NORMALCHORD play mode. This success code indicates
 * that the caller should not do anything with the note. It is not meant
 * to be played against this chord.
 */
Public Const DMUS_S_OVER_CHORD               = &H8781212 'MAKE_DMHRESULTSUCCESS(0x212)

/* DMUS_S_UP_OCTAVE
 *
 * Returned from IDirectMusicPerformance::MIDIToMusic(),  and
 * IDirectMusicPerformance::MusicToMIDI(), this indicates 
 * that the note conversion generated a note value that is below 0, 
 * so it has been bumped up one or more octaves to be in the proper
 * MIDI range of 0 through 127. 
 * Note that this is valid for MIDIToMusic() when using play modes
 * DMUS_PLAYMODE_FIXEDTOCHORD and DMUS_PLAYMODE_FIXEDTOKEY, both of
 * which store MIDI values in wMusicValue. With MusicToMIDI(), it is
 * valid for all play modes.
 * Ofcourse, DMUS_PLAYMODE_FIXED will never return this success code.
 */
Public Const DMUS_S_UP_OCTAVE                = &H8781213 'MAKE_DMHRESULTSUCCESS(0x213)

/* DMUS_S_DOWN_OCTAVE
 *
 * Returned from IDirectMusicPerformance::MIDIToMusic(),  and
 * IDirectMusicPerformance::MusicToMIDI(), this indicates 
 * that the note conversion generated a note value that is above 127, 
 * so it has been bumped down one or more octaves to be in the proper
 * MIDI range of 0 through 127. 
 * Note that this is valid for MIDIToMusic() when using play modes
 * DMUS_PLAYMODE_FIXEDTOCHORD and DMUS_PLAYMODE_FIXEDTOKEY, both of
 * which store MIDI values in wMusicValue. With MusicToMIDI(), it is
 * valid for all play modes.
 * Ofcourse, DMUS_PLAYMODE_FIXED will never return this success code.
 */
Public Const DMUS_S_DOWN_OCTAVE              = &H8781214 'MAKE_DMHRESULTSUCCESS(0x214)

/* DMUS_S_NOBUFFERCONTROL
 *
 * Although the audio output from the port will be routed to the
 * same device as the given DirectSound buffer, buffer controls
 * such as pan and volume will not affect the output.
 *
 */
Public Const DMUS_S_NOBUFFERCONTROL          = &H8781215 'MAKE_DMHRESULTSUCCESS(0x215)

/* DMUS_S_GARBAGE_COLLECTED
 *
 * The requested operation was not performed because during CollectGarbage
 * the loader determined that the object had been released.
 */
Public Const DMUS_S_GARBAGE_COLLECTED        = &H8781216 'MAKE_DMHRESULTSUCCESS(0x216)
/* DMUS_E_DRIVER_FAILED
*
* An unexpected error was returned from a device driver, indicating
* possible failure of the driver or hardware.
*/
Public Const DMUS_E_DRIVER_FAILED            = &H88781101 'MAKE_DMHRESULTERROR(0x0101)
/* DMUS_E_PORTS_OPEN
*
* The requested operation cannot be performed while there are 
* instantiated ports in any process in the system.
*/
Public Const DMUS_E_PORTS_OPEN               = &H88781102 'MAKE_DMHRESULTERROR(0x0102)

/* DMUS_E_DEVICE_IN_USE
*
* The requested device is already in use (possibly by a non-DirectMusic
* client) and cannot be opened again.
*/
Public Const DMUS_E_DEVICE_IN_USE            = &H88781103 'MAKE_DMHRESULTERROR(0x0103)

/* DMUS_E_INSUFFICIENTBUFFER
*
* Buffer is not large enough for requested operation.
*/
Public Const DMUS_E_INSUFFICIENTBUFFER       = &H88781104 'MAKE_DMHRESULTERROR(0x0104)

/* DMUS_E_BUFFERNOTSET
*
* No buffer was prepared for the download data.
*/
Public Const DMUS_E_BUFFERNOTSET             = &H88781105'MAKE_DMHRESULTERROR(0x0105)

/* DMUS_E_BUFFERNOTAVAILABLE
*
* Download failed due to inability to access or create download buffer.
*/
Public Const DMUS_E_BUFFERNOTAVAILABLE       = &H88781106 'MAKE_DMHRESULTERROR(0x0106)

/* DMUS_E_NOTADLSCOL
*
* Error parsing DLS collection. File is corrupt.
*/
Public Const DMUS_E_NOTADLSCOL               = &H88781108 'MAKE_DMHRESULTERROR(0x0108)

/* DMUS_E_INVALIDOFFSET
