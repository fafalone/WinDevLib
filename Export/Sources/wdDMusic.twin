*/
Public Const DMUS_E_TYPE_DISABLED            = &H88781163 'MAKE_DMHRESULTERROR(0x0163)

/* DMUS_E_TYPE_UNSUPPORTED
*
* The requested parameter type is not supported on the object.
*/
Public Const DMUS_E_TYPE_UNSUPPORTED         = &H88781164 'MAKE_DMHRESULTERROR(0x0164)

/* DMUS_E_TIME_PAST
*
* The time is in the past, and the operation can not succeed.
*/
Public Const DMUS_E_TIME_PAST                = &H88781165 'MAKE_DMHRESULTERROR(0x0165)

/* DMUS_E_TRACK_NOT_FOUND
*
* The requested track is not contained by the segment.
*/
Public Const DMUS_E_TRACK_NOT_FOUND            = &H88781166 'MAKE_DMHRESULTERROR(0x0166)

/* DMUS_E_TRACK_NO_CLOCKTIME_SUPPORT
*
* The track does not support clock time playback or getparam.
*/
Public Const DMUS_E_TRACK_NO_CLOCKTIME_SUPPORT   = &H88781167 'MAKE_DMHRESULTERROR(0x0167)
 
/* DMUS_E_NO_MASTER_CLOCK
*
* There is no master clock in the performance. Be sure to call
* IDirectMusicPerformance::Init().
*/
Public Const DMUS_E_NO_MASTER_CLOCK          = &H88781170 'MAKE_DMHRESULTERROR(0x0170)

/* DMUS_E_LOADER_NOCLASSID
*
* The class id field is required and missing in the DMUS_OBJECTDESC.
*/
Public Const DMUS_E_LOADER_NOCLASSID         = &H88781180 'MAKE_DMHRESULTERROR(0x0180)

/* DMUS_E_LOADER_BADPATH
*
* The requested file path is invalid.
*/
Public Const DMUS_E_LOADER_BADPATH           = &H88781181 'MAKE_DMHRESULTERROR(0x0181)

/* DMUS_E_LOADER_FAILEDOPEN
*
* File open failed - either file doesn't exist or is locked.
*/
Public Const DMUS_E_LOADER_FAILEDOPEN        = &H88781182 'MAKE_DMHRESULTERROR(0x0182)

/* DMUS_E_LOADER_FORMATNOTSUPPORTED
*
* Search data type is not supported.
*/
Public Const DMUS_E_LOADER_FORMATNOTSUPPORTED    = &H88781183 'MAKE_DMHRESULTERROR(0x0183)

/* DMUS_E_LOADER_FAILEDCREATE
*
* Unable to find or create object.
*/
Public Const DMUS_E_LOADER_FAILEDCREATE      = &H88781184 'MAKE_DMHRESULTERROR(0x0184)

/* DMUS_E_LOADER_OBJECTNOTFOUND
*
* Object was not found.
*/
Public Const DMUS_E_LOADER_OBJECTNOTFOUND    = &H88781185 'MAKE_DMHRESULTERROR(0x0185)

/* DMUS_E_LOADER_NOFILENAME
*
* The file name is missing from the DMUS_OBJECTDESC.
*/
Public Const DMUS_E_LOADER_NOFILENAME        = &H88781186 'MAKE_DMHRESULTERROR(0x0186)

/* DMUS_E_INVALIDFILE
*
