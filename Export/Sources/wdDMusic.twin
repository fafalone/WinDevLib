*/
Public Const DMUS_E_ALREADY_SENT             = &H88781204 'MAKE_DMHRESULTERROR(0x0204)

/* DMUS_E_CANNOT_FREE
*
* The DMUS_PMSG was either not allocated by the performance via
* IDirectMusicPerformance::AllocPMsg(), or it was already freed via
