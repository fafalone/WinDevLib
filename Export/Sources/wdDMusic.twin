Public Enum DMusicIoWaveTrackFlags
	/* This flag is included in DMUS_IO_WAVE_TRACK_HEADER.dwFlags.  If set, the track will get its 
	variations from a pattern track, via GetParam(GUID_Variations). */
	DMUS_WAVETRACKF_SYNC_VAR = &H1
	/* This is also included in DMUS_IO_WAVE_TRACK_HEADER.dwFlags.  If set, variation control 
	information will persist from one playback instance to the next.*/
	DMUS_WAVETRACKF_PERSIST_CONTROL = &H2
End Enum

Public Type DMUS_IO_WAVE_TRACK_HEADER
	lVolume As Long '* Gain, in 1/100th of dB, to be applied to all waves.  Note:  All gain values should be negative. */
	dwFlags As Long '* Flags, including whether this track syncs to a pattern track for its variations. */
End Type

Public Type DMUS_IO_WAVE_PART_HEADER
	lVolume As Long '* Gain, in 1/100th of dB, to be applied to all waves in wave part.  Note:  All gain values should be negative. */
	dwVariations As Long '* Variation mask for which of 32 variations */
	dwPChannel As Long '* PChannel */
	dwLockToPart As Long '* Part ID to lock to. */
	dwFlags As Long ' Flags, including stuff for managing how variations are chosen (in low-order nibble) */
	dwIndex As Long '* Index for distinguishing multiple parts on the same PChannel*/
End Type

Public Type DMUS_IO_WAVE_ITEM_HEADER
	lVolume As Long '* Gain, in 1/100th of dB.  Note:  All gain values should be negative. */
	lPitch As Long '* Pitch offset in 1/100th of a semitone. */
	dwVariations As Long '* Variation flags for which of 32 variations this wave belongs to. */
	rtTime As REFERENCE_TIME '*/ Start time, in REFERENCE_TIME, if clock time track, or MUSIC_TIME for music time track. */
	rtStartOffset As REFERENCE_TIME '*/ Distance into wave to start playback, in reference time units. */
	rtReserved As REFERENCE_TIME '*/ Reserved field. */
	rtDuration As REFERENCE_TIME '*/ Duration, in REFERENCE_TIME or MUSIC_TIME, depending on track timing format. */
	mtLogicalTime As MUSIC_TIME '*/ If in music track format, this indicates the musical boundary where this belongs. Otherwise, ignored. */
	dwLoopStart As Long '* Start point for a looping wave. */
	dwLoopEnd As Long '* End point for a looping wave. */
	dwFlags As Long ' Various flags, including whether this is a streaming wave and whether it can be invalidated. */
	wVolumeRange As Integer '* Random range for volume. */
	wPitchRange As Integer '* Random range for pitch. */
End Type

