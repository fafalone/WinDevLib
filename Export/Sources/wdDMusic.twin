*/
Public Const DMUS_E_OUT_OF_RANGE             = &H88781202 'MAKE_DMHRESULTERROR(0x0202)

/* DMUS_E_SEGMENT_INIT_FAILED
*
* Segment initialization failed, most likely due to a critical memory situation.
*/
Public Const DMUS_E_SEGMENT_INIT_FAILED      = &H88781203 'MAKE_DMHRESULTERROR(0x0203)

/* DMUS_E_ALREADY_SENT
*
* The DMUS_PMSG has already been sent to the performance object via
