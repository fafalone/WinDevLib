	punkUser As IUnknown '* user com pointer, auto released upon PMSG free */
	mtDuration As MUSIC_TIME '* how long this curve lasts */
	mtOriginalStart As MUSIC_TIME '* must be set to either zero when this PMSG is created or to the original mtTime of the curve */
	mtResetDuration As MUSIC_TIME '* how long after the curve is finished to allow a flush or
	'   invalidation to reset to the reset value, nResetValue */
	nStartValue As Integer '* curve's start value */
	nEndValue As Integer '* curve's end value */
	nResetValue As Integer '* curve's reset value, set when a flush or invalidation
	'   occurs within mtDuration + mtResetDuration */
	wMeasure As Integer '* Measure in which this curve occurs */
	nOffset As Integer '* Offset from grid at which this curve occurs */
	bBeat As Byte '* Beat (in measure) at which this curve occurs */
	bGrid As Byte '* Grid offset from beat at which this curve occurs */
	bType As Byte '* type of curve */
	bCurveShape As Byte '* shape of curve */
	bCCData As Byte '* CC# if this is a control change type */
	bFlags As Byte '* Curve reset and start from current value flags. */
	'* Following exists only under DX8 and on (check dwFlags for DMUS_PMSGF_DX8) */
	wParamType As Integer '* RPN or NRPN parameter number. */
	wMergeIndex As Integer '* Allows multiple parameters to be merged (pitchbend, volume, and expression.)*/
End Type

Public Enum DMUS_CURVE_FLAGS
	DMUS_CURVE_RESET = 1 ' When set, the nResetValue must be sent when the
	'                                         time is reached or an invalidate occurs because
	'                                         of a transition. If not set, the curve stays
	'                                         permanently stuck at the new value. */
	DMUS_CURVE_START_FROM_CURRENT = 2 ' Ignore Start, start the curve at the current value.
	'                                         This only works for volume, expression, and pitchbend. */
End Enum

