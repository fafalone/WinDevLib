*/
Public Const DMUS_E_NOARTICULATION           = &H88781129 'MAKE_DMHRESULTERROR(0x0129)

/* DMUS_E_NOTPCM
*
* Downoaded DLS wave is not in PCM format. 
*/
Public Const DMUS_E_NOTPCM                   = &H8878112a 'MAKE_DMHRESULTERROR(0x012A)

/* DMUS_E_BADWAVE
*
* Bad wave chunk in DLS collection
*/
Public Const DMUS_E_BADWAVE                  = &H8878112b 'MAKE_DMHRESULTERROR(0x012B)

/* DMUS_E_BADOFFSETTABLE
*
* Offset Table for download buffer has errors. 
*/
Public Const DMUS_E_BADOFFSETTABLE           = &H8878112c 'MAKE_DMHRESULTERROR(0x012C)

/* DMUS_E_UNKNOWNDOWNLOAD
*
* Attempted to download unknown data type.
*/
Public Const DMUS_E_UNKNOWNDOWNLOAD          = &H8878112d 'MAKE_DMHRESULTERROR(0x012D)

/* DMUS_E_NOSYNTHSINK
*
* The operation could not be completed because no sink was connected to
