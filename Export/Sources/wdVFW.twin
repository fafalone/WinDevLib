    Public Function AVICapSM(ByVal hwnd As LongPtr, ByVal m As Long, ByVal w As LongPtr, ByVal l As LongPtr) As LongPtr
        Return If(IsWindow(hwnd), SendMessage(hwnd, m, w, ByVal l), CLngPtr(0))
    End Function
