    Public Const MCIWNDM_GETSTYLES  = (WM_USER + 136)
    Public Const MCIWNDM_GETALIAS  = (WM_USER + 137)
    Public Const MCIWNDM_PLAYREVERSE  = (WM_USER + 139)
