    Public Type CAPDRIVERCAPS
        wDeviceIndex As Long ' Driver index in system.ini
        fHasOverlay As BOOL ' Can device overlay?
        fHasDlgVideoSource As BOOL ' Has Video source dlg?
        fHasDlgVideoFormat As BOOL ' Has Format dlg?
        fHasDlgVideoDisplay As BOOL ' Has External out dlg?
        fCaptureInitialized As BOOL ' Driver ready to capture?
        fDriverSuppliesPalettes As BOOL ' Can driver make palettes?
        ' following always NULL on Win32.
        hVideoIn As LongPtr ' Driver In channel
        hVideoOut As LongPtr ' Driver Out channel
        hVideoExtIn As LongPtr ' Driver Ext In channel
        hVideoExtOut As LongPtr ' Driver Ext Out channel
    End Type
    
    Public Type CAPSTATUS
        uiImageWidth As Long ' Width of the image
        uiImageHeight As Long ' Height of the image
        fLiveWindow As BOOL ' Now Previewing video?
        fOverlayWindow As BOOL ' Now Overlaying video?
        fScale As BOOL ' Scale image to client?
        ptScroll As POINT ' Scroll position
        fUsingDefaultPalette As BOOL ' Using default driver palette?
        fAudioHardware As BOOL ' Audio hardware present?
        fCapFileExists As BOOL ' Does capture file exist?
        dwCurrentVideoFrame As Long ' # of video frames cap'td
        dwCurrentVideoFramesDropped As Long ' # of video frames dropped
        dwCurrentWaveSamples As Long ' # of wave samples cap'td
        dwCurrentTimeElapsedMS As Long ' Elapsed capture duration
        hPalCurrent As LongPtr 'HPALETTE ' Current palette in use
        fCapturingNow As BOOL ' Capture in progress?
        dwReturn As Long ' Error value after any operation
        wNumVideoAllocated As Long ' Actual number of video buffers
        wNumAudioAllocated As Long ' Actual number of audio buffers
    End Type
    
    Public Type CAPTUREPARMS
        dwRequestMicroSecPerFrame As Long ' Requested capture rate
        fMakeUserHitOKToCapture As BOOL ' Show "Hit OK to cap" dlg?
        wPercentDropForError As Long ' Give error msg if > (10%)
        fYield As BOOL ' Capture via background task?
        dwIndexSize As Long ' Max index size in frames (32K)
        wChunkGranularity As Long ' Junk chunk granularity (2K)
        fUsingDOSMemory As BOOL ' Use DOS buffers?
        wNumVideoRequested As Long ' # video buffers, If 0, autocalc
        fCaptureAudio As BOOL ' Capture audio?
        wNumAudioRequested As Long ' # audio buffers, If 0, autocalc
        vKeyAbort As Long ' Virtual key causing abort
        fAbortLeftMouse As BOOL ' Abort on left mouse?
        fAbortRightMouse As BOOL ' Abort on right mouse?
        fLimitEnabled As BOOL ' Use wTimeLimit?
        wTimeLimit As Long ' Seconds to capture
        fMCIControl As BOOL ' Use MCI video source?
        fStepMCIDevice As BOOL ' Step MCI device?
        dwMCIStartTime As Long ' Time to start in MS
        dwMCIStopTime As Long ' Time to stop in MS
        fStepCaptureAt2x As BOOL ' Perform spatial averaging 2x
        wStepCaptureAverageFrames As Long ' Temporal average n Frames
        dwAudioBufferSize As Long ' Size of audio bufs (0 = default)
        fDisableWriteCache As BOOL ' Attempt to disable write cache
        AVStreamMaster As Long ' Which stream controls length?
    End Type
    
    Public Const AVSTREAMMASTER_AUDIO       = 0 /* Audio master (VFW 1.0, 1.1) */
    Public Const AVSTREAMMASTER_NONE        = 1 /* No master */
    
    Public Type CAPINFOCHUNK
        fccInfoID As Long 'FOURCC ' Chunk ID, "ICOP" for copyright
        lpData As LongPtr ' pointer to data
        cbData As Long ' size of lpData
    End Type

