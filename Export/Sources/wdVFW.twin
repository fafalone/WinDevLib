    Public Const MCIWNDM_SETTIMEFORMATA  = (WM_USER + 119)
    Public Const MCIWNDM_GETTIMEFORMATA  = (WM_USER + 120)
    Public Const MCIWNDM_GETFILENAMEA  = (WM_USER + 124)
    Public Const MCIWNDM_GETDEVICEA  = (WM_USER + 125)
    Public Const MCIWNDM_GETERRORA  = (WM_USER + 128)
    Public Const MCIWNDM_NEWA  = (WM_USER + 134)
    Public Const MCIWNDM_RETURNSTRINGA  = (WM_USER + 138)
    Public Const MCIWNDM_OPENA  = (WM_USER + 153)
    Public Const MCIWNDM_SENDSTRINGW  = (WM_USER + 201)
    Public Const MCIWNDM_GETPOSITIONW  = (WM_USER + 202)
