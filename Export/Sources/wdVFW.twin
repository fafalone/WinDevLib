    Public Const MCIWNDM_SENDSTRING  = MCIWNDM_SENDSTRINGW
    Public Const MCIWNDM_GETPOSITION  = MCIWNDM_GETPOSITIONW
    Public Const MCIWNDM_GETMODE  = MCIWNDM_GETMODEW
    Public Const MCIWNDM_SETTIMEFORMAT  = MCIWNDM_SETTIMEFORMATW
    Public Const MCIWNDM_GETTIMEFORMAT  = MCIWNDM_GETTIMEFORMATW
    Public Const MCIWNDM_GETFILENAME  = MCIWNDM_GETFILENAMEW
    Public Const MCIWNDM_GETDEVICE  = MCIWNDM_GETDEVICEW
    Public Const MCIWNDM_GETERROR  = MCIWNDM_GETERRORW
    Public Const MCIWNDM_NEW  = MCIWNDM_NEWW
    Public Const MCIWNDM_RETURNSTRING  = MCIWNDM_RETURNSTRINGW
    Public Const MCIWNDM_OPEN  = MCIWNDM_OPENW
    '  note that the source text for MCIWND will thus contain
    '  support for eg MCIWNDM_SENDSTRING (both the 16-bit entrypoint and
    '  in win32 mapped to MCIWNDM_SENDSTRINGW), and MCIWNDM_SENDSTRINGA (the
    '  win32 ansi thunk).
    '  Messages MCIWND will send to an app
    '  !!! Use less messages and use a code instead to indicate the type of notify? /* ;Internal */
    Public Const MCIWNDM_NOTIFYMODE  = (WM_USER + 200)  ' wp = hwnd, lp = mode
    Public Const MCIWNDM_NOTIFYPOS  = (WM_USER + 201)  ' wp = hwnd, lp = pos
    Public Const MCIWNDM_NOTIFYSIZE  = (WM_USER + 202)  ' wp = hwnd
    Public Const MCIWNDM_NOTIFYMEDIA  = (WM_USER + 203)  ' wp = hwnd, lp = fn
    Public Const MCIWNDM_NOTIFYERROR  = (WM_USER + 205)  ' wp = hwnd, lp = error
    '  special seek values for START and END
    Public Const MCIWND_START  = -1
    Public Const MCIWND_END  = -2
    
    
    Public Declare PtrSafe Function VideoForWindowsVersion Lib "msvfw32" () As Long

    Public Const DV_ERR_OK  = (0) /* No error */
    Public Const DV_ERR_BASE  = (1) /* Error Base */
    Public Const DV_ERR_NONSPECIFIC  = (DV_ERR_BASE)
    Public Const DV_ERR_BADFORMAT  = (DV_ERR_BASE + 1)
    /* unsupported video format */
    Public Const DV_ERR_STILLPLAYING  = (DV_ERR_BASE + 2)
                    /* still something playing */
    Public Const DV_ERR_UNPREPARED  = (DV_ERR_BASE + 3)
                    /* header not prepared */
    Public Const DV_ERR_SYNC  = (DV_ERR_BASE + 4)
                    /* device is synchronous */
    Public Const DV_ERR_TOOMANYCHANNELS  = (DV_ERR_BASE + 5)
                    /* number of channels exceeded */
    Public Const DV_ERR_NOTDETECTED  = (DV_ERR_BASE + 6) /* HW not detected */
    Public Const DV_ERR_BADINSTALL  = (DV_ERR_BASE + 7) /* Can not get Profile */
    Public Const DV_ERR_CREATEPALETTE  = (DV_ERR_BASE + 8)
    Public Const DV_ERR_SIZEFIELD  = (DV_ERR_BASE + 9)
    Public Const DV_ERR_PARAM1  = (DV_ERR_BASE + 10)
    Public Const DV_ERR_PARAM2  = (DV_ERR_BASE + 11)
    Public Const DV_ERR_CONFIG1  = (DV_ERR_BASE + 12)
    Public Const DV_ERR_CONFIG2  = (DV_ERR_BASE + 13)
    Public Const DV_ERR_FLAGS  = (DV_ERR_BASE + 14)
    Public Const DV_ERR_13  = (DV_ERR_BASE + 15)
    Public Const DV_ERR_NOTSUPPORTED  = (DV_ERR_BASE + 16) /* function not suported */
    Public Const DV_ERR_NOMEM  = (DV_ERR_BASE + 17) /* out of memory */
    Public Const DV_ERR_ALLOCATED  = (DV_ERR_BASE + 18) /* device is allocated */
    Public Const DV_ERR_BADDEVICEID  = (DV_ERR_BASE + 19)
    Public Const DV_ERR_INVALHANDLE  = (DV_ERR_BASE + 20)
    Public Const DV_ERR_BADERRNUM  = (DV_ERR_BASE + 21)
    Public Const DV_ERR_NO_BUFFERS  = (DV_ERR_BASE + 22) /* out of buffers */
    Public Const DV_ERR_MEM_CONFLICT  = (DV_ERR_BASE + 23) /* Mem conflict detected */
    Public Const DV_ERR_IO_CONFLICT  = (DV_ERR_BASE + 24) /* I/O conflict detected */
    Public Const DV_ERR_DMA_CONFLICT  = (DV_ERR_BASE + 25) /* DMA conflict detected */
    Public Const DV_ERR_INT_CONFLICT  = (DV_ERR_BASE + 26) /* Interrupt conflict detected */
    Public Const DV_ERR_PROTECT_ONLY  = (DV_ERR_BASE + 27) /* Can not run in standard mode */
    Public Const DV_ERR_LASTERROR  = (DV_ERR_BASE + 27)
    ' #define DV_IDS_PROFILING        (DV_ERR_BASE + 900)
    ' #define DV_IDS_LISTBOX          (DV_ERR_BASE + 901)
    Public Const DV_ERR_USER_MSG  = (DV_ERR_BASE + 1000) /* Hardware specific errors */

    Public Const DV_VM_OPEN  = MM_DRVM_OPEN  ' Obsolete messages
    Public Const DV_VM_CLOSE  = MM_DRVM_CLOSE
    Public Const DV_VM_DATA  = MM_DRVM_DATA
    Public Const DV_VM_ERROR  = MM_DRVM_ERROR

    
    Public Enum VideoHdrFlags
        VHDR_DONE = &H00000001  '* Done bit */
        VHDR_PREPARED = &H00000002  '* Set if this header has been prepared */
        VHDR_INQUEUE = &H00000004  '* Reserved for driver */
        VHDR_KEYFRAME = &H00000008  '* Key Frame */
        VHDR_VALID = &H0000000F  '* valid flags */     /* ;Internal */
    End Enum
    Public Type VIDEOHDR
        lpData As LongPtr '* pointer to locked data buffer */
        dwBufferLength As Long '* Length of data buffer */
        dwBytesUsed As Long '* Bytes actually used */
        dwTimeCaptured As Long '* Milliseconds from start of stream */
        dwUser As LongPtr '* for client's use */
        dwFlags As VideoHdrFlags '* assorted flags (see defines) */
        dwReserved(0 To 3) As LongPtr '* reserved for driver */
    End Type

    Public Enum ChannelCapsFlags
        VCAPS_OVERLAY = &H00000001 /* overlay channel */
        VCAPS_SRC_CAN_CLIP = &H00000002 /* src rect can clip */
        VCAPS_DST_CAN_CLIP = &H00000004 /* dst rect can clip */
        VCAPS_CAN_SCALE = &H00000008 /* allows src != dst */
    End Enum
    Public Type CHANNEL_CAPS
        dwFlags As ChannelCapsFlags /* Capability flags*/
        dwSrcRectXMod As Long '* Granularity of src rect in x */
        dwSrcRectYMod As Long '* Granularity of src rect in y */
        dwSrcRectWidthMod As Long '* Granularity of src rect width */
        dwSrcRectHeightMod As Long '* Granularity of src rect height */
        dwDstRectXMod As Long '* Granularity of dst rect in x */
        dwDstRectYMod As Long '* Granularity of dst rect in y */
        dwDstRectWidthMod As Long '* Granularity of dst rect width */
        dwDstRectHeightMod As Long '* Granularity of dst rect height */
    End Type

    Public Const VIDEO_EXTERNALIN  = &H0001
    Public Const VIDEO_EXTERNALOUT  = &H0002
    Public Const VIDEO_IN  = &H0004
    Public Const VIDEO_OUT  = &H0008
    '  Is a driver dialog available for this channel?
    Public Const VIDEO_DLG_QUERY  = &H0010
    '  videoConfigure (both GET and SET)
    Public Const VIDEO_CONFIGURE_QUERY  = &H8000
    '  videoConfigure (SET only)
    Public Const VIDEO_CONFIGURE_SET  = &H1000
    '  videoConfigure (GET only)
