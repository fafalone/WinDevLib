' #endif /*  ODBCVER >= &H0300 */

' /* Lock options in SQLSetPos */
Public Const SQL_LOCK_NO_CHANGE         = 0 /*    = 1.0 FALSE */
Public Const SQL_LOCK_EXCLUSIVE         = 1 /*    = 1.0 TRUE */
Public Const SQL_LOCK_UNLOCK            = 2

Public Const SQL_SETPOS_MAX_LOCK_VALUE      = SQL_LOCK_UNLOCK
/* Macros for SQLSetPos */
Public Function SQL_POSITION_TO(hstmt As SQLHSTMT, irow As SQLUSMALLINT) As SQLRETURN
    Return SQLSetPos(hstmt, irow, SQL_POSITION, SQL_LOCK_NO_CHANGE)
End Function

Public Function SQL_LOCK_RECORD(hstmt As SQLHSTMT, irow As SQLUSMALLINT, fLock As SQLUSMALLINT) As SQLRETURN
    Return SQLSetPos(hstmt, irow, SQL_POSITION, fLock)
End Function

Public Function SQL_REFRESH_RECORD(hstmt As SQLHSTMT, irow As SQLUSMALLINT, fLock As SQLUSMALLINT) As SQLRETURN
    Return SQLSetPos(hstmt, irow, SQL_REFRESH, fLock)
End Function

Public Function SQL_UPDATE_RECORD(hstmt As SQLHSTMT, irow As SQLUSMALLINT) As SQLRETURN
    Return SQLSetPos(hstmt, irow, SQL_UPDATE, SQL_LOCK_NO_CHANGE)
End Function

Public Function SQL_DELETE_RECORD(hstmt As SQLHSTMT, irow As SQLUSMALLINT) As SQLRETURN
    Return SQLSetPos(hstmt, irow, SQL_DELETE, SQL_LOCK_NO_CHANGE)
End Function

Public Function SQL_ADD_RECORD(hstmt As SQLHSTMT, irow As SQLUSMALLINT) As SQLRETURN
    Return SQLSetPos(hstmt, irow, SQL_ADD, SQL_LOCK_NO_CHANGE)
End Function

