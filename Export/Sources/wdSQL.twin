' /* Defines for SQLSetPos */
Public Const SQL_ENTIRE_ROWSET          = 0

' /* Operations in SQLSetPos */
Public Const SQL_POSITION               = 0 /*    = 1.0 FALSE */
Public Const SQL_REFRESH                = 1 /*    = 1.0 TRUE */
Public Const SQL_UPDATE                 = 2
Public Const SQL_DELETE                 = 3

' /* Operations in SQLBulkOperations */
Public Const SQL_ADD                    = 4
Public Const SQL_SETPOS_MAX_OPTION_VALUE        = SQL_ADD
