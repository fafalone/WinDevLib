/* Functions for setting the connection pooling failure detection code */
/* The "TryWait" value is the time (in seconds) that the DM will wait  */
/* between detecting that a connection is dead (using                  */
/* SQL_ATTR_CONNECTION_DEAD) and retrying the connection.  During that */
/* interval, connection requests will get "The server appears to be    */
/* dead" error returns.                                                */


Public Declare PtrSafe Function ODBCSetTryWaitValue Lib "odbc32.dll" (ByVal dwValue As Long) As BOOL
Public Declare PtrSafe Function ODBCGetTryWaitValue Lib "odbc32.dll" () As Long

Public Const ODBC_VS_FLAG_UNICODE_ARG  = &H00000001 /* the argument is unicode */
Public Const ODBC_VS_FLAG_UNICODE_COR  = &H00000002 /* the correlation is unicode */
Public Const ODBC_VS_FLAG_RETCODE  = &H00000004 /* RetCode field is set */
Public Const ODBC_VS_FLAG_STOP  = &H00000008 /* Stop firing visual studio analyzer events */

Public Type ODBC_VS_ARGS
    pguidEvent As LongPtr 'const GUID* '* the GUID for event */
    dwFlags As Long '* flags for the call */
    'union {
    '    WCHAR   *wszArg;
    '    CHAR    *szArg;
    '};
    wszArg As LongPtr
    'union {
    '    WCHAR   *wszCorrelation;
    '    CHAR    *szCorrelation;
    '};
    wszCorrelation As LongPtr
    RetCode As Integer
End Type

[Description("Unknown DLL. Provided as delegate to load yourself.")]
Public Delegate Sub FireVSDebugEvent (ByRef pova As ODBC_VS_ARGS)


