Public Const SQL_NEED_DATA  = 99
/* test for SQL_SUCCESS or SQL_SUCCESS_WITH_INFO */
Public Function SQL_SUCCEEDED(ByVal rc As Long) As Boolean
Return (((rc) And (Not 1)) = 0)
End Function

