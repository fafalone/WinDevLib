'sqlucode.h - 100%
'sqlext.h - 100%

'Note: The compiler const ODBC_STD is supported.

Public Alias SQLCHAR As String 'Byte
Public Alias SQLSCHAR As Byte
Public Alias SQLDATE As Byte
Public Alias SQLDECIMAL As Byte
Public Alias SQLDOUBLE As Double
Public Alias SQLFLOAT As Double
Public Alias SQLINTEGER As Long
Public Alias SQLUINTEGER As Long
#If Win64 Then
Public Alias SQLLEN As LongLong
Public Alias SQLULEN As LongLong
Public Alias SQLSETPOSIROW As LongLong
#Else
Public Alias SQLLEN As SQLINTEGER
Public Alias SQLULEN As SQLUINTEGER
Public Alias SQLSETPOSIROW As SQLUSMALLINT
#End If

Public Alias SQLROWCOUNT As SQLULEN
Public Alias SQLROWSETSIZE As SQLULEN
Public Alias SQLTRANSID As SQLULEN
Public Alias SQLROWOFFSET As SQLLEN

Public Alias SQLNUMERIC As Byte
Public Alias SQLPOINTER As LongPtr
Public Alias SQLREAL As Single
Public Alias SQLSMALLINT As Integer
Public Alias SQLUSMALLINT As Integer

Public Alias SQLTIME As Byte
Public Alias SQLTIMESTAMP As Byte
Public Alias SQLVARCHAR As Byte

Public Alias SQLRETURN As SQLSMALLINT

Public Alias SQLHANDLE As LongPtr

Public Alias SQLHENV As SQLHANDLE
Public Alias SQLHDBC As SQLHANDLE
Public Alias SQLHSTMT As SQLHANDLE
Public Alias SQLHDESC As SQLHANDLE

Public Alias SQLHWND As LongPtr

Public Alias SQL_DATE_STRUCT As DATE_STRUCT
Public Alias SQL_TIME_STRUCT As TIME_STRUCT
Public Alias SQL_TIMESTAMP_STRUCT As TIMESTAMP_STRUCT

Public Alias ODBCINT64 As LongLong
Public Alias SQLBIGINT As ODBCINT64
Public Alias SQLUBIGINT As ODBCINT64

Public Alias SQLGUID As UUID

Public Alias SQLWCHAR As String 'Integer
Public Alias SQLTCHAR As SQLWCHAR


Module wdSQL

Public Const ODBCVER  = &H0380
    
Public Type DATE_STRUCT
    year As SQLSMALLINT
    month As SQLUSMALLINT
    day As SQLUSMALLINT
End Type

Public Type TIME_STRUCT
    hour As SQLUSMALLINT
    minute As SQLUSMALLINT
    second As SQLUSMALLINT
End Type

Public Type TIMESTAMP_STRUCT
    year As SQLSMALLINT
    month As SQLUSMALLINT
    day As SQLUSMALLINT
    hour As SQLUSMALLINT
    minute As SQLUSMALLINT
    second As SQLUSMALLINT
    fraction As SQLUINTEGER
End Type

Public Enum SQLINTERVAL
    SQL_IS_YEAR = 1
    SQL_IS_MONTH = 2
    SQL_IS_DAY = 3
    SQL_IS_HOUR = 4
    SQL_IS_MINUTE = 5
    SQL_IS_SECOND = 6
    SQL_IS_YEAR_TO_MONTH = 7
    SQL_IS_DAY_TO_HOUR = 8
    SQL_IS_DAY_TO_MINUTE = 9
    SQL_IS_DAY_TO_SECOND = 10
    SQL_IS_HOUR_TO_MINUTE = 11
    SQL_IS_HOUR_TO_SECOND = 12
    SQL_IS_MINUTE_TO_SECOND = 13
End Enum

Public Type SQL_YEAR_MONTH_STRUCT
    year As SQLUINTEGER
    month As SQLUINTEGER
End Type

Public Type SQL_DAY_SECOND_STRUCT
    day As SQLUINTEGER
    hour As SQLUINTEGER
    minute As SQLUINTEGER
    second As SQLUINTEGER
    fraction As SQLUINTEGER
End Type

[Description("NOTE: intval is a union. For the SQL_YEAR_MONTH_STRUCT arm, the year value is stored in day, and month in hour.")]
Public Type SQL_INTERVAL_STRUCT
    interval_type As SQLINTERVAL
    interval_sign As SQLSMALLINT
    'union {
    '    SQL_YEAR_MONTH_STRUCT        year_month;
    '    SQL_DAY_SECOND_STRUCT        day_second;
    '} intval;
    intval As SQL_DAY_SECOND_STRUCT
End Type

Public Const SQL_MAX_NUMERIC_LEN  = 16

Public Type SQL_NUMERIC_STRUCT
    precision As SQLCHAR
    scale As SQLSCHAR
    sign As SQLCHAR /* 1 if positive, 0 if negative */
    val(0 To (SQL_MAX_NUMERIC_LEN - 1)) As SQLCHAR
End Type

#Region "sql.h"

