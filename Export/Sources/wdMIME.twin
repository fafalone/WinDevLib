    Public Const CP_ISO2022JPSIO As Long = 50222
    
    Public Const CCHMAX_CSET_NAME As Integer = 128
    Public Const CCHMAX_LANG_NAME As Integer = 128
    Public Const CCHMAX_FACE_NAME As Integer = 128
    
    Public Type INETCSETINFO
		szName(0 To (CCHMAX_CSET_NAME - 1)) As Byte ' Character Set name
		hCharset As LongPtr ' Handle to this character set
		cpiWindows As Long ' Windows CodePage
		cpiInternet As Long ' Internet Code Page
		dwReserved1 As Long ' Reserved, don't use
	End Type
    
    Public Enum INETLANGMASK
		ILM_FAMILY = &H00000001 ' CODEPAGEINFO::dwFamily is valid
		ILM_NAME = &H00000002 ' CODEPAGEINFO::szName is valid
		ILM_BODYCSET = &H00000004 ' CODEPAGEINFO::szBodyCset is valid
		ILM_HEADERCSET = &H00000008 ' CODEPAGEINFO::szHeadCset is valid
		ILM_WEBCSET = &H00000010 ' CODEPAGEINFO::szWebCset is valid
		ILM_FIXEDFONT = &H00000020 ' CODEPAGEINFO::szFixedFont is valid
		ILM_VARIABLEFONT = &H00000040 ' CODEPAGEINFO::szVariableFont is valid
	End Enum
    
    Public Type CODEPAGEINFO
		dwMask As Long ' Describes which fields are valid (INETLANGMASK)
		cpiCodePage As Long ' Handle to this charset (code page number / mlangid)
		fIsValidCodePage As BOOL ' Value of IsValidCodePage(idCodePage)
		ulMaxCharSize As Long ' Maximum width of a character in this codepage
		fInternetCP As BOOL ' Is this an Internet Code Page
		cpiFamily As Long ' Windows Code page if fInternetCP == TRUE
		szName(0 To (CCHMAX_LANG_NAME - 1)) As Byte ' Language Name
		szBodyCset(0 To (CCHMAX_CSET_NAME - 1)) As Byte ' Charset to be used for the body
		szHeaderCset(0 To (CCHMAX_CSET_NAME - 1)) As Byte ' Charset to be used for the Header
		szWebCset(0 To (CCHMAX_CSET_NAME - 1)) As Byte ' Charset to be used for the body
		szFixedFont(0 To (CCHMAX_FACE_NAME - 1)) As Byte ' Fixed Width Font Face Name
		szVariableFont(0 To (CCHMAX_FACE_NAME - 1)) As Byte ' Variable Width Font Face Name
		ietNewsDefault As ENCODINGTYPE ' Default news mime encoding (FMT_BASE64 or FMT_QP)
		ietMailDefault As ENCODINGTYPE ' Default mail mime encoding (FMT_BASE64 or FMT_QP)
		dwReserved1 As Long ' Reserved, don't use
	End Type
    
