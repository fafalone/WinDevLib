    Function FindCharset(ByVal pszCharset As String /* ANSI */) As LongPtr
    Sub GetCharsetInfo(ByVal hCharset As LongPtr, ByRef pCsetInfo As INETCSETINFO)
    Sub GetCodePageInfo(ByVal cpiCodePage As Long, ByRef pCodePageInfo As CODEPAGEINFO)
    Sub CanConvertCodePages(ByVal cpiSource As Long, ByVal cpiDest As Long)
    Sub DecodeHeader(ByVal hCharset As LongPtr, ByVal pszData As String /* ANSI */, ByRef pDecoded As Variant, ByRef pRfc1522Info As RFC1522INFO)
    Sub EncodeHeader(ByVal hCharset As LongPtr, ByRef pData As Variant, ByRef ppszEncoded As LongPtr /* ANSI */, ByRef pRfc1522Info As RFC1522INFO)
    Sub ConvertBuffer(ByVal cpiSource As Long, ByVal cpiDest As Long, ByRef pIn As BLOB, ByRef pOut As BLOB, ByRef pcbRead As Long)
    Sub ConvertString(ByVal cpiSource As Long, ByVal cpiDest As Long, ByRef pIn As Variant, ByRef pOut As Variant)
