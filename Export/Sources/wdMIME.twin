		IMF_SUBMULTIPART = &H00000004 ' The message has a nested multipart section
		IMF_MIME = &H00000008 ' The message is in MIME format
		IMF_HTML = &H00000010 ' The message has a text/html body
		IMF_PLAIN = &H00000020 ' The message has a text/plain body
		IMF_PARTIAL = &H00000040 ' The message has un-matching boundaries, or is a message/partial
		IMF_SIGNED = &H00000080 ' The message is signed
		IMF_ENCRYPTED = &H00000100 ' The message is secured
		IMF_TNEF = &H00000200 ' The message has a Microsoft TNEF attachment
		IMF_MHTML = &H00000400 ' The message has a MIME-HTML multipart/related section
		IMF_SECURE = &H00000800 ' The message has a cryptographic enhancement
		IMF_TEXT = &H00001000 ' The message contains text/xxx part(s)
		IMF_CSETTAGGED = &H00002000 ' The message was tagged with a charset
		IMF_NEWS = &H00004000 ' The message has nntp (news) headers (Newsgroup, Path, etc)
		IMF_VOICEMAIL = &H00008000& ' The message has the X-Voicemail Header Set to something
		IMF_HASVCARD = &H00010000 ' The message has a text/v-card attachment.
		IMF_RFC1154 = &H00020000 ' The message was decoded using RFC1154.
	End Enum

