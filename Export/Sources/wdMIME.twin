    Sub Rfc1522Decode(ByVal pszValue As String /* ANSI */, ByVal pszCharset As String /* ANSI */, ByVal cchmax As Long, ByRef ppszDecoded As LongPtr /* ANSI */)
    Sub Rfc1522Encode(ByVal pszValue As String /* ANSI */, ByVal hCharset As Long, ByRef ppszEncoded As LongPtr /* ANSI */)
End Interface

