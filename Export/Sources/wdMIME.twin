    Public Function IID_IMimeInfo() As UUID
    '{F77459A0-BF9A-11cf-BA4E-00C04FD70816}
    Static iid As UUID
     If (iid.Data1 = 0) Then Call DEFINE_UUID(iid, &HF77459A0, CInt(&HBF9A), CInt(&H11cf), &HBA, &H4E, &H00, &HC0, &H4F, &HD7, &H08, &H16)
     IID_IMimeInfo = iid
    End Function
    Public Function SID_IMimeInfo() As UUID
    Return IID_IMimeInfo
    End Function
    
    
    
