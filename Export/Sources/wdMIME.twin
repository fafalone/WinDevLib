    Public Const CMS_RECIPIENT_INFO_TYPE_KEYTRANS  = 1
    Public Const CMS_RECIPIENT_INFO_TYPE_KEYAGREE  = 2
    Public Const CMS_RECIPIENT_INFO_TYPE_MAIL_LIST  = 3
    Public Const CMS_RECIPIENT_INFO_PUBKEY_CERTIFICATE  = 0
    Public Const CMS_RECIPIENT_INFO_PUBKEY_KEYTRANS  = 1
    Public Const CMS_RECIPIENT_INFO_PUBKEY_PROVIDER  = 2
    Public Const CMS_RECIPIENT_INFO_PUBKEY_EPHEMERAL_KEYAGREE  = 3
    Public Const CMS_RECIPIENT_INFO_PUBKEY_STATIC_KEYAGREE  = 4
    Public Const CMS_RECIPIENT_INFO_KEYID_CERTIFICATE  = 0
