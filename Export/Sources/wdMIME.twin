    Public Type CMS_RECIPIENT_INFO
		dwRecipientType As Long
		pccert As LongPtr 'PCCERT_CONTEXT
		KeyEncryptionAlgorithm As CRYPT_ALGORITHM_IDENTIFIER
		pvKeyEncryptionAuxInfo As LongPtr 'void
		cbKeyEncryptionAuxInfo As Long
		KeyWrapAlgorithm As CRYPT_ALGORITHM_IDENTIFIER
		pvKeyWrapAuxInfo As LongPtr 'void
		cbKeyWrapAuxInfo As Long
		dwU1 As Long
		'[switch_type(DWORD), switch_is(dwU1)]
		'union {
		'    [case(1)] CRYPT_BIT_BLOB SubjectPublicKey;
		'    [case(2)] struct {
		'        HCRYPTPROV          hprov;
		'        HCRYPTKEY           hkey;
		'    } u2;
		'    [case(3)] struct {
		'        CRYPT_DATA_BLOB     UserKeyingMaterial;
		'        CRYPT_ALGORITHM_IDENTIFIER EphemeralAlgorithm;
		'        CRYPT_BIT_BLOB      SubjectPublicKey;
		'    } u3;
		'    [case(4)] struct {
		'        CRYPT_DATA_BLOB     UserKeyingMaterial;
		'        HCRYPTPROV          hprov;
		'        DWORD               dwKeySpec;
		'        CERT_ID             senderCertId;
		'        CRYPT_BIT_BLOB      SubjectPublicKey;
		'    } u4;
		'} u1;
		#If Win64 Then
		u1(95) As Byte
		#Else
		u1(47) As Byte
		#End If
		'  KEY ID
		'  Key Ids are:
		'  1) IssuerAndSerialNumber
		'  2) SKI + filetime + attributes
		'  3) KI + filetime + attributes
		dwU3 As Long
		'[switch_type(DWORD), switch_is(dwU3)]
		'union {
		'    [case(1)] CERT_ISSUER_SERIAL_NUMBER     IssuerSerial;
		'    [case(2)] CRYPT_DATA_BLOB               KeyId;
		'} u3;
		#If Win64 Then
		u3(31) As Byte
		#Else
		u(15) As Byte
		#End If
		filetime As FILETIME
		pOtherAttr As LongPtr 'PCRYPT_ATTRIBUTE_TYPE_VALUE 
	End Type
	
