    ' } CMS_CTRL_DECRYPT_INFO, *PCMS_CTRL_DECYRPT_INFO;
	Public Type CMS_CTRL_DECRYPT_INFO
		#If Win64 Then
        u(63) As Byte
        #Else
        u(35) as Byte     
        #End If
    End Type
	
    Public Function IID_IMimeSecurity2() As UUID
    Static iid As UUID
     If (iid.Data1 = 0) Then Call DEFINE_UUID(iid, &H80830b40, &H962c, &H11d2, &H8a, &Hf6, &H00, &H80, &Hc7, &H6b, &H34, &Hc6)
    IID_IMimeSecurity2 = iid
    End Function
    
