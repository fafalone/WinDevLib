' wdMIME
' Covers mimelib.tlb, additions to source headers, and some additional headers.
' Redone from SDK headers, many bug fixes.
' Note that some constants and type/enum names have had prefixes added due to short, generic 
' names likely to cause conflicts.
'
' Headers covered: mimeole.idl, msoeapi.idl, imnact.id, MimeInfo.h/.idl and mimedisp.h



[InterfaceId("C5588349-7F86-11D0-8252-00C04FD85AB4")]
[OleAutomation(False)]
