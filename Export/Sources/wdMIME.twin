		FOLDERID_ROOT = &H00000000&
		FOLDERID_INVALID = &HFFFFFFFF&
     End Enum

     Public Enum MSOEAPI_SpecialMessages
		MSGID_INVALID = &HFFFFFFFF&
		MSGID_FIRST = &HFFFFFFFF&
     End Enum
     
     Public Const CCHMAX_FOLDER_NAME = 256

     Public Enum MSOEAPI_NotificationMessages
		WM_FOLDERNOTIFY = (WM_USER + 1600)  ' IStoreNamespace Notification - lparam=LPFOLDERNOTIFYEX, client must call CoTaskMemFree(lParam)")
		WM_NEWMSGS = (WM_USER + 1650)  ' IStoreFolder Notification: wParam=MESSAGEID, lParam=Reserved")
		WM_DELETEMSGS = (WM_USER + 1651)  ' IStoreFolder Notification: wParam=prgdwMsgId, lParam=cMsgs")
		WM_DELETEFOLDER = (WM_USER + 1652)  ' IStoreFolder Notification: wParam=STOREFOLDERID or HFOLDER")
	'  If wParam is equal to 0xffffffff then that means that all messages in the folder
	'  were either marked as read (WM_MARKEDASREAD) or unread (WM_MARKEDASUNREAD)
		WM_MARKEDASREAD = (WM_USER + 1653)  ' IStoreFolder Notification: wParamprgdwMsgId, lParam=cMsgs")
		WM_MARKEDASUNREAD = (WM_USER + 1654)  ' IStoreFolder Notification: wParamprgdwMsgId, lParam=cMsgs")
     End Enum

     Public Enum FOLDERNOTIFYTYPE
		MSOEAPI_NEW_FOLDER = &H00000001&
		MSOEAPI_DELETE_FOLDER = &H00000002&
		MSOEAPI_RENAME_FOLDER = &H00000003&
		MSOEAPI_MOVE_FOLDER = &H00000004&
		MSOEAPI_UNREAD_CHANGE = &H00000005&
		MSOEAPI_IMAPFLAG_CHANGE = &H00000006&
		MSOEAPI_UPDATEFLAG_CHANGE = &H00000007&
		MSOEAPI_FOLDER_PROPS_CHANGED = &H00000008&
     End Enum

     Public Type FOLDERNOTIFYEX
		type As FOLDERNOTIFYTYPE
		idFolderOld As Long 'STOREFOLDERID ' not used for CREATEFOLDER and DELETEFOLDER
		idFolderNew As Long 'STOREFOLDERID
	End Type
    
    Public Type MESSAGEIDLIST
		cbSize As Long ' Sizeof this structure
		cMsgs As Long ' Number of elements in prghMessage
		prgdwMsgId As LongPtr 'LPMESSAGEID ' Array of handles to messages
	End Type
    
    Public Enum MSOEAPI_SPECIALFOLDER
		FOLDER_NOTSPECIAL = -1 ' Not a special folder
		FOLDER_INBOX ' Default receive folder
		FOLDER_OUTBOX ' Default send folder
		FOLDER_SENT ' Things that have been sent
		FOLDER_DELETED ' Things that have been deleted
		FOLDER_DRAFT ' Things that are in progress
		FOLDER_MAX ' Don't use
	End Enum
    
    Public Type FOLDERPROPS
		cbSize As Long 'FOLDERPROPSSIZE ' Size of this structure
		dwFolderId As Long 'STOREFOLDERID ' Handle of this folder
		cSubFolders As Long ' Number of sub-folders
		sfType As MSOEAPI_SPECIALFOLDER ' Special folder type
		cUnread As Long ' Number of un-read messages
		cMessage As Long ' Total # of messages
		szName(0 To (CCHMAX_FOLDER_NAME - 1)) As Byte ' The Folder Name
	End Type
    
    Public Enum MimeCopyMoveMessagesFlags
		CMF_MOVE = &H0001  ' msgs deleted from src fldr after copy")
		CMF_DELETE = &H0002
	End Enum
    
    Public Enum MessageStateFlags
		MSG_DELETED = &H0001  ' The message has been deleted, compaction will remove it")
		MSG_UNREAD = &H0002  ' The message is marked as un-read")
		MSG_SUBMITTED = &H0004  ' For messages waiting to be sent: OUTBOX ONLY")
		MSG_UNSENT = &H0008  ' For msgs-in-progress saved to a folder")
		MSG_RECEIVED = &H0010  ' For messages that came from a server")
		MSG_NEWSMSG = &H0020  ' For news messages")
		MSG_NOSECUI = &H0040  ' For messages where the user wants to die")
		MSG_VOICEMAIL = &H0080  ' The message has the X-Voicemail header set...")
		MSG_REPLIED = &H0100  ' The message has been replied to")
		MSG_FORWARDED = &H0200  ' The message has been forwarded to")
		MSG_RCPTSENT = &H0400  ' S/MIME Receipt has been sent")
		MSG_FLAGGED = &H0800  ' The message is currently flaged")
		MSG_LAST = &H0200  ' ** Keep this updated!! **")
		MSG_EXTERNAL_FLAGS = &H00fe
		MSG_FLAGS = &H000f
	End Enum
    
    Public Type MESSAGEPROPS
		cbSize As Long 'MESSAGEPROPSSIZE ' Size of this structure
		dwReserved As Long ' Reserved don't use
		dwMessageId As Long 'MESSAGEID ' Handle to this message
		dwLanguage As Long ' Codepage of this message
		dwState As MessageStateFlags ' MSG_xxx Flags
		' Things you don't get when MSGPROPS_FAST
		cbMessage As Long ' Size of the message
		priority As IMSGPRIORITY ' Message Priority
		ftReceived As FILETIME ' When the message was received
		ftSent As FILETIME ' When the message was sent
		pszSubject As String ' The subject of the message
		pszDisplayTo As String ' The display to line of the message
		pszDisplayFrom As String ' The display from line of the message
		pszNormalSubject As String ' The normalized subject of the message
		dwFlags As IMSGFLAGS ' IMF_xxx Flags defined in idl
		pStmOffsetTable As IStream ' Use with IMimeMessage::LoadOffsetTable
	End Type
    
    Public Enum GetMessagePropsFlags
		MSGPROPS_FAST = &H00000001&
    End Enum

    Public Enum CommitStreamFlags
		COMMITSTREAM_REVERT = &H00000001&
    End Enum
    
