Public Const XACTPARAMETERVALUE_MIN         As XACTVARIABLEVALUE = -FLT_MAX
Public Const XACTPARAMETERVALUE_MAX         As XACTVARIABLEVALUE = FLT_MAX
Public Const XACTLOOPCOUNT_MIN              As XACTLOOPCOUNT = &H0
Public Const XACTLOOPCOUNT_MAX              As XACTLOOPCOUNT = &HFE
Public Const XACTLOOPCOUNT_INFINITE         As XACTLOOPCOUNT = &HFF
Public Const XACTWAVEALIGNMENT_MIN          As Long = 2048

'  -----------------------------------------------------------------------------
' Cue friendly name length
'  -----------------------------------------------------------------------------
Public Const XACT_CUE_NAME_LENGTH  = &HFF
'  -----------------------------------------------------------------------------
'  Current Content Tool Version
'  -----------------------------------------------------------------------------
Public Const XACT_CONTENT_VERSION  = 46

' -----------------------------------------------------------------------------
' XACT Stop Flags
' -----------------------------------------------------------------------------
Public Const XACT_FLAG_STOP_RELEASE             As Long = &H00000000 ' Stop with release envelope (or as authored), for looping waves this acts as break loop.
Public Const XACT_FLAG_STOP_IMMEDIATE           As Long = &H00000001 ' Stop immediately
' -----------------------------------------------------------------------------
' XACT Manage Data Flag - XACT will manage the lifetime of this data
' -----------------------------------------------------------------------------
Public Const XACT_FLAG_MANAGEDATA               As Long = &H00000001
' -----------------------------------------------------------------------------
' XACT Content Preparation Flags
' -----------------------------------------------------------------------------
Public Const XACT_FLAG_BACKGROUND_MUSIC         As Long = &H00000002 ' Marks the waves as background music.
Public Const XACT_FLAG_UNITS_MS                 As Long = &H00000004 ' Indicates that the units passed in are in milliseconds.
Public Const XACT_FLAG_UNITS_SAMPLES            As Long = &H00000008 ' Indicates that the units passed in are in samples.
' -----------------------------------------------------------------------------
' XACT State flags
' -----------------------------------------------------------------------------
Public Const XACT_STATE_CREATED                 As Long = &H00000001 ' Created, but nothing else
Public Const XACT_STATE_PREPARING               As Long = &H00000002 ' In the middle of preparing
Public Const XACT_STATE_PREPARED                As Long = &H00000004 ' Prepared, but not yet played
Public Const XACT_STATE_PLAYING                 As Long = &H00000008 ' Playing (though could be paused)
Public Const XACT_STATE_STOPPING                As Long = &H00000010 ' Stopping
Public Const XACT_STATE_STOPPED                 As Long = &H00000020 ' Stopped
Public Const XACT_STATE_PAUSED                  As Long = &H00000040 ' Paused (Can be combined with some of the other state flags above)
Public Const XACT_STATE_INUSE                   As Long = &H00000080 ' Object is in use (used by wavebanks and soundbanks).
Public Const XACT_STATE_PREPAREFAILED           As Long = &H80000000 ' Object preparation failed.


