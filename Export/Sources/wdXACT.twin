Public Const XACT_FLAG_API_AUDITION_MODE = &H00000001
Public Const XACT_FLAG_API_DEBUG_MODE    = &H00000002

Public Const XACT_DEBUGENGINE_REGISTRY_KEY  = "Software\Microsoft\XACT"
Public Const XACT_DEBUGENGINE_REGISTRY_VALUE  = "DebugEngine"

Public Function XACT3CreateEngine(ByVal dwCreationFlags As Long, ppEngine As IXACT3Engine) As Long
    Dim hr       As Long
    Dim key      As LongPtr
    Dim data     As Long
    Dim dataType As Long = REG_DWORD
    Dim dataSize As Long = LenB(Of Long)
    Dim bDebug   As Boolean = If(dwCreationFlags And XACT_FLAG_API_DEBUG_MODE, True, False)
    Dim audition As Boolean = If(dwCreationFlags And XACT_FLAG_API_AUDITION_MODE, True, False)

    ' If neither the debug nor audition flags are set, see if the debug registry key is set
    If (Not bDebug) And (Not audition) Then
        If RegOpenKeyEx(HKEY_LOCAL_MACHINE, XACT_DEBUGENGINE_REGISTRY_KEY, 0, KEY_READ, key) = ERROR_SUCCESS Then
            If RegQueryValueEx(key, XACT_DEBUGENGINE_REGISTRY_VALUE, ByVal 0, dataType, data, dataSize) = ERROR_SUCCESS Then
                If data Then bDebug = True
            End If
            RegCloseKey key
        End If
    End If

    ' Priority order: Audition, Debug, Retail 
    Dim cls As UUID
    If audition Then
        cls = CLSID_XACTAuditionEngine
    ElseIf bDebug Then
        cls = CLSID_XACTDebugEngine
    Else
        cls = CLSID_XACTEngine
    End If
    hr = CoCreateInstance(cls, Nothing, CLSCTX_INPROC_SERVER, IID_IXACT3Engine, ppEngine)

    ' If debug engine does not exist fallback to retail version
    If FAILED(hr) And bDebug And (Not audition) Then
        hr = CoCreateInstance(CLSID_XACTEngine, Nothing, CLSCTX_INPROC_SERVER, IID_IXACT3Engine, ppEngine)
    End If
    
    Return hr
End Function

