Public Type XACT_RENDERER_DETAILS
    rendererID(0 To (XACT_RENDERER_ID_LENGTH - 1)) As Integer ' The string ID for the rendering device.
    displayName(0 To (XACT_RENDERER_NAME_LENGTH - 1)) As Integer ' A friendly name suitable for display to a human.
    defaultDevice As BOOL ' Set to TRUE if this device is the primary audio device on the system.
End Type

Public Const XACT_ENGINE_LOOKAHEAD_DEFAULT  = 250  ' Default look-ahead time of 250ms can be used during XACT engine initialization.

Public Type XACT_RUNTIME_PARAMETERS
    lookAheadTime As Long ' Time in ms
    pGlobalSettingsBuffer As LongPtr ' Buffer containing the global settings file
    globalSettingsBufferSize As Long ' Size of global settings buffer
    globalSettingsFlags As Long ' Flags for global settings
    globalSettingsAllocAttributes As Long ' Global settings buffer allocation attributes (see XMemAlloc)
    fileIOCallbacks As XACT_FILEIO_CALLBACKS ' File I/O callbacks
    fnNotificationCallback As XACT_NOTIFICATION_CALLBACK ' Callback that receives notifications.
    pRendererID As LongPtr ' Ptr to the ID for the audio renderer the engine should connect to.
