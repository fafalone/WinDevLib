    Sub PrepareStreamingWave(ByVal dwFlags As Long, ByVal entry_dwFlagsAndDuration As Long, ByVal entry_Format_dwValue As Long, ByVal entry_PlayRegion_dwOffset As Long, ByVal entry_PlayRegion_dwLength As Long, ByVal entry_LoopRegion_dwStartSample As Long, ByVal entry_LoopRegion_dwTotalSamples As Long, ByVal streamingParams_file As LongPtr, ByVal streamingParams_offset As Long, ByVal streamingParams_flags As Long, ByVal streamingParams_packetSize As Integer, ByVal streamingParams_pad as Integer, ByVal dwAlignment As Long, pdwSeekTable As Long, ByVal dwPlayOffset As Long, ByVal nLoopCount As XACTLOOPCOUNT, ppWave As IXACT3Wave)
