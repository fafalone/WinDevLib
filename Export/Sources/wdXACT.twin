'XACT3 audio engine

'xma2defs.h
'xact3wb.h
'xact3.h
'audiodefs.h (mostly covered in other files)

#If WDL_NO_DIRECTX = 0 Then

Public Alias XACTINDEX As Integer            ' All normal indices
Public Alias XACTNOTIFICATIONTYPE As Byte    ' Notification type
Public Alias XACTVARIABLEVALUE As Single     ' Variable value
Public Alias XACTVARIABLEINDEX As Integer    ' Variable index
Public Alias XACTCATEGORY As Integer         ' Sound category
Public Alias XACTCHANNEL As Byte             ' Audio channel
Public Alias XACTVOLUME As Single            ' Volume value
Public Alias XACTTIME As Long                ' Time (in ms)
Public Alias XACTPITCH As Integer            ' Pitch value
Public Alias XACTLOOPCOUNT As Byte           ' For all loops / recurrences
Public Alias XACTVARIATIONWEIGHT As Byte     ' Variation weight
Public Alias XACTPRIORITY As Byte            ' Sound priority
Public Alias XACTINSTANCELIMIT As Byte       ' Instance limitations

Public Alias XACT_WAVEBANK_STREAMING_PARAMETERS As XACT_STREAMING_PARAMETERS

[OleAutomation(False)]
Interface IXACT3SoundBank Extends Nothing
    [PreserveSig]
    Function GetCueIndex(ByVal szFriendlyName As LongPtr /* ANSI */) As XACTINDEX
    Sub GetNumCues(pnNumCues As XACTINDEX)
    Sub GetCueProperties(ByVal nCueIndex As XACTINDEX, pProperties As XACT_CUE_PROPERTIES)
    Sub Prepare(ByVal nCueIndex As XACTINDEX, ByVal dwFlags As Long, ByVal timeOffset As XACTTIME, ppCue As IXACT3Cue)
    Sub Play(ByVal nCueIndex As XACTINDEX, ByVal dwFlags As Long, ByVal timeOffset As XACTTIME, ppCue As IXACT3Cue)
    Sub Stop(ByVal nCueIndex As XACTINDEX, ByVal dwFlags As Long)
    Sub Destroy()
    Sub GetState(pdwState As Long)
End Interface

[OleAutomation(False)]
Interface IXACT3WaveBank Extends Nothing
    Sub Destroy()
    Sub GetNumWaves(pnNumWaves As XACTINDEX)
    [PreserveSig]
    Function GetWaveIndex(ByVal szFriendlyName As LongPtr /* ANSI */) As XACTINDEX
    Sub GetWaveProperties(ByVal nWaveIndex As XACTINDEX, pWaveProperties As XACT_WAVE_PROPERTIES)
    Sub Prepare(ByVal nWaveIndex As XACTINDEX, ByVal dwFlags As Long, ByVal dwPlayOffset As Long, ByVal nLoopCount As XACTLOOPCOUNT, ppWave As IXACT3Wave)
    Sub Play(ByVal nWaveIndex As XACTINDEX, ByVal dwFlags As Long, ByVal dwPlayOffset As Long, ByVal nLoopCount As XACTLOOPCOUNT, ppWave As IXACT3Wave)
    Sub Stop(ByVal nWaveIndex As XACTINDEX, ByVal dwFlags As Long)
    Sub GetState(pdwState As Long)
End Interface

[OleAutomation(False)]
Interface IXACT3Wave Extends Nothing
    Sub Destroy()
    Sub Play()
    Sub Stop(ByVal dwFlags As Long)
    Sub Pause(ByVal fPause As BOOL)
    Sub GetState(pdwState As Long)
    Sub SetPitch(ByVal pitch As XACTPITCH)
    Sub SetVolume(ByVal volume As XACTVOLUME)
    Sub SetMatrixCoefficients(ByVal uSrcChannelCount As Long, ByVal uDstChannelCount As Long, pMatrixCoefficients As Single)
    Sub GetProperties(pProperties As XACT_WAVE_INSTANCE_PROPERTIES)
End Interface

[OleAutomation(False)]
Interface IXACT3Cue Extends Nothing
    Sub Play()
    Sub Stop(ByVal dwFlags As Long)
    Sub GetState(pdwState As XACTCueStates)
    Sub Destroy()
    Sub SetMatrixCoefficients(ByVal uSrcChannelCount As Long, ByVal uDstChannelCount As Long, pMatrixCoefficients As Single)
    [PreserveSig]
    Function GetVariableIndex(ByVal szFriendlyName As LongPtr /* ANSI */) As XACTVARIABLEINDEX
    Sub SetVariable(ByVal nIndex As XACTVARIABLEINDEX, ByVal nValue As XACTVARIABLEVALUE)
    Sub GetVariable(ByVal nIndex As XACTVARIABLEINDEX, nValue As XACTVARIABLEVALUE)
    Sub Pause(ByVal fPause As BOOL)
    Sub GetProperties(ppProperties As LongPtr /* XACT_CUE_INSTANCE_PROPERTIES** */)
    Sub SetOutputVoices(pSendList As XAUDIO2_VOICE_SENDS)
    Sub SetOutputVoiceMatrix(ByVal pDestinationVoice As IXAudio2Voice, ByVal SourceChannels As Long, ByVal DestinationChannels As Long, pLevelMatrix As Single)
End Interface

#If WDL_NO_BYVAL_UDT = 0 Then
[InterfaceId("B1EE676A-D9CD-4D2A-89A8-FA53EB9E480B")]
[OleAutomation(False)]
Interface IXACT3Engine Extends IUnknown
    Sub GetRendererCount(pnRendererCount As XACTINDEX)
    Sub GetRendererDetails(ByVal nRendererIndex As XACTINDEX, pRendererDetails As XACT_RENDERER_DETAILS)
    Sub GetFinalMixFormat(pFinalMixFormat As WAVEFORMATEXTENSIBLE)
    Sub Initialize(pParams As XACT_RUNTIME_PARAMETERS)
    Sub ShutDown()
    Sub DoWork()
    Sub CreateSoundBank(pvBuffer As Any, ByVal dwSize As Long, ByVal dwFlags As Long, ByVal dwAllocAttributes As Long, ppSoundBank As IXACT3SoundBank)
    Sub CreateInMemoryWaveBank(pvBuffer As Any, ByVal dwSize As Long, ByVal dwFlags As Long, ByVal dwAllocAttributes As Long, ppWaveBank As IXACT3WaveBank)
