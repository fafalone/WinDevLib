End Type

Public Type XACT_STREAMING_PARAMETERS
    file As LongPtr         ' File handle associated with wavebank data
    offset As Long          ' Offset within file of wavebank header (must be sector aligned)
    flags As Long           ' Flags (none currently)
    packetSize As Integer   ' Stream packet size (in sectors) to use for each stream (min = 2)
                            '   number of sectors (DVD = 2048 bytes: 2 = 4096, 3 = 6144, 4 = 8192 etc.)
                            '   optimal DVD size is a multiple of 16 (DVD block = 16 DVD sectors)
End Type
'Alias XACT_WAVEBANK_STREAMING_PARAMETERS As XACT_STREAMING_PARAMETERS

Public Type XACT_CUE_PROPERTIES
    friendlyName(0 To (XACT_CUE_NAME_LENGTH - 1)) As Byte ' Empty if the soundbank doesn't contain any friendly names
    interactive As BOOL ' TRUE if an IA cue; FALSE otherwise
    iaVariableIndex As XACTINDEX ' Only valid for IA cues; XACTINDEX_INVALID otherwise
    numVariations As XACTINDEX ' Number of variations in the cue
    maxInstances As XACTINSTANCELIMIT ' Number of maximum instances for this cue
    currentInstances As XACTINSTANCELIMIT ' Current active instances of this cue
End Type

Public Type XACT_TRACK_PROPERTIES
    duration As XACTTIME ' Duration of the track in ms
    numVariations As XACTINDEX ' Number of wave variations in the track
    numChannels As XACTCHANNEL ' Number of channels for the active wave variation on this track
    waveVariation As XACTINDEX ' Index of the active wave variation
    loopCount As XACTLOOPCOUNT ' Current loop count on this track
End Type

Public Type XACT_VARIATION_PROPERTIES
    index As XACTINDEX ' Index of the variation in the cue's variation list
    weight As XACTVARIATIONWEIGHT ' Weight for the active variation. Valid only for complex cues
    iaVariableMin As XACTVARIABLEVALUE ' Valid only for IA cues
    iaVariableMax As XACTVARIABLEVALUE ' Valid only for IA cues
    linger As BOOL ' Valid only for IA cues
End Type

Public Type XACT_SOUND_PROPERTIES
    category As XACTCATEGORY ' Category this sound belongs to
    priority As Byte ' Priority of this variation
    pitch As XACTPITCH ' Current pitch set on the active variation
    volume As XACTVOLUME ' Current volume set on the active variation
    numTracks As XACTINDEX ' Number of tracks in the active variation
    arrTrackProperties(0 To 0) As XACT_TRACK_PROPERTIES ' Array of active track properties (has numTracks number of elements)
End Type

Public Type XACT_SOUND_VARIATION_PROPERTIES
    variationProperties As XACT_VARIATION_PROPERTIES ' Properties for this variation
    soundProperties As XACT_SOUND_PROPERTIES ' Proeprties for the sound referenced by this variation
End Type

Public Type XACT_CUE_INSTANCE_PROPERTIES
    allocAttributes As Long ' Buffer allocation attributes (see XMemAlloc)
    cueProperties As XACT_CUE_PROPERTIES ' Properties of the cue that are shared by all instances.
    activeVariationProperties As XACT_SOUND_VARIATION_PROPERTIES ' Properties if the currently active variation.
End Type

Public Type XACT_WAVE_PROPERTIES
    friendlyName(0 To (WAVEBANK_ENTRYNAME_LENGTH - 1)) As Byte ' Friendly name for the wave; empty if the wavebank doesn't contain friendly names.
    format As WAVEBANKMINIWAVEFORMAT ' Format for the wave.
    durationInSamples As Long ' Duration of the wave in units of one sample
    loopRegion As WAVEBANKSAMPLEREGION ' Loop region defined in samples.
    streaming As BOOL ' Set to TRUE if the wave is streaming; FALSE otherwise.
End Type

Public Type XACT_WAVE_INSTANCE_PROPERTIES
    properties As XACT_WAVE_PROPERTIES ' Static properties common to all the wave instances.
    backgroundMusic As BOOL ' Set to TRUE if the wave is tagged as background music; FALSE otherwise.
End Type

