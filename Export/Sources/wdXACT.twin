    Sub PrepareWave(ByVal dwFlags As Long, ByVal szWavePath As LongPtr /* ANSI */, ByVal wStreamingPacketSize As Integer, ByVal dwAlignment As Long, ByVal dwPlayOffset As Long, ByVal nLoopCount As XACTLOOPCOUNT, ppWave As IXACT3Wave)
    Sub PrepareInMemoryWave(ByVal dwFlags As Long, ByVal entry As WAVEBANKENTRY, pdwSeekTable As Long, pbWaveData As Any, ByVal dwPlayOffset As Long, ByVal nLoopCount As XACTLOOPCOUNT, ppWave As IXACT3Wave)
    Sub PrepareStreamingWave(ByVal dwFlags As Long, ByVal entry As WAVEBANKENTRY, ByVal streamingParams As XACT_STREAMING_PARAMETERS, ByVal dwAlignment As Long, pdwSeekTable As Long, ByVal dwPlayOffset As Long, ByVal nLoopCount As XACTLOOPCOUNT, ppWave As IXACT3Wave)
