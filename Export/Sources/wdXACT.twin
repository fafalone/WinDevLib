#Region "xact3d3.h"

'  Supported speaker positions, represented as azimuth angles.
'  Here's a picture of the azimuth angles for the 8 cardinal points,
'  seen from above.  The emitter's base position is at the origin 0.
'            FRONT
'              | 0  <-- azimuth
'              |
'     7pi/4 \  |  / pi/4
'            \ | /
'  LEFT       \|/      RIGHT
'  3pi/2-------0-------pi/2
'             /|\
'            / | \
'     5pi/4 /  |  \ 3pi/4
'              |
'              | pi
'            BACK
Public Const LEFT_AZIMUTH As Single = (3! * X3DAUDIO_PI / 2!)
Public Const RIGHT_AZIMUTH As Single = (X3DAUDIO_PI / 2!)
Public Const FRONT_LEFT_AZIMUTH As Single = (7 * X3DAUDIO_PI / 4!)
Public Const FRONT_RIGHT_AZIMUTH As Single = (X3DAUDIO_PI / 4!)
Public Const FRONT_CENTER_AZIMUTH As Single = 0.0!
Public Const LOW_FREQUENCY_AZIMUTH As Single = X3DAUDIO_2PI
Public Const BACK_LEFT_AZIMUTH As Single = (5! * X3DAUDIO_PI / 4!)
Public Const BACK_RIGHT_AZIMUTH As Single = (3! * X3DAUDIO_PI / 4!)
Public Const BACK_CENTER_AZIMUTH As Single = X3DAUDIO_PI
Public Const FRONT_LEFT_OF_CENTER_AZIMUTH As Single = (15! * X3DAUDIO_PI / 8!)
Public Const FRONT_RIGHT_OF_CENTER_AZIMUTH As Single = (X3DAUDIO_PI / 8!)

Public Function aStereoLayout() As Single()
    Dim arr(0 To 1) As Single
    arr(0) = LEFT_AZIMUTH
    arr(1) = RIGHT_AZIMUTH
    aStereoLayout = arr
End Function

Public Function a2Point1Layout() As Single()
    Dim arr(0 To 2) As Single
    arr(0) = LEFT_AZIMUTH
    arr(1) = RIGHT_AZIMUTH
    arr(2) = LOW_FREQUENCY_AZIMUTH
    a2Point1Layout = arr
End Function

Public Function aQuadLayout() As Single()
    Dim arr(0 To 3) As Single
    arr(0) = FRONT_LEFT_AZIMUTH
    arr(1) = FRONT_RIGHT_AZIMUTH
    arr(2) = BACK_LEFT_AZIMUTH
    arr(3) = BACK_RIGHT_AZIMUTH
    aQuadLayout = arr
End Function

Public Function a4Point1Layout() As Single()
    Dim arr(0 To 4) As Single
    arr(0) = FRONT_LEFT_AZIMUTH
    arr(1) = FRONT_RIGHT_AZIMUTH
    arr(2) = LOW_FREQUENCY_AZIMUTH
    arr(3) = BACK_LEFT_AZIMUTH
    arr(4) = BACK_RIGHT_AZIMUTH
    a4Point1Layout = arr
End Function

Public Function a5Point1Layout() As Single()
    Dim arr(0 To 5) As Single
    arr(0) = FRONT_LEFT_AZIMUTH
    arr(1) = FRONT_RIGHT_AZIMUTH
    arr(2) = FRONT_CENTER_AZIMUTH
    arr(3) = LOW_FREQUENCY_AZIMUTH
    arr(4) = BACK_LEFT_AZIMUTH
    arr(5) = BACK_RIGHT_AZIMUTH
    a5Point1Layout = arr
End Function

Public Function a7Point1Layout() As Single()
    Dim arr(0 To 7) As Single
    arr(0) = FRONT_LEFT_AZIMUTH
    arr(1) = FRONT_RIGHT_AZIMUTH
    arr(2) = FRONT_CENTER_AZIMUTH
    arr(3) = LOW_FREQUENCY_AZIMUTH
    arr(4) = BACK_LEFT_AZIMUTH
    arr(5) = BACK_RIGHT_AZIMUTH
    arr(6) = LEFT_AZIMUTH
    arr(7) = RIGHT_AZIMUTH
    a7Point1Layout = arr
End Function

Public Function XACT3DInitialize(pEngine As IXACT3Engine, X3DInstance As X3DAUDIO_HANDLE) As Long ' HRESULT
    Dim hr As Long
    hr = S_OK
    On Error Resume Next
    
    If pEngine Is Nothing Then
        hr = E_POINTER
    End If

    Dim nSpeedOfSound As Single ' XACTVARIABLEVALUE
    If SUCCEEDED(hr) Then
        Dim xactSpeedOfSoundID As Integer ' XACTVARIABLEINDEX
        xactSpeedOfSoundID = pEngine.GetGlobalVariableIndex(StrPtr(CStr(StrConv("SpeedOfSound", vbFromUnicode))))
        pEngine.GetGlobalVariable(xactSpeedOfSoundID, nSpeedOfSound)
        hr = Err.LastHresult
    End If

    If SUCCEEDED(hr) Then
        Dim wfxFinalMixFormat As WAVEFORMATEXTENSIBLE
        pEngine.GetFinalMixFormat(wfxFinalMixFormat)
        hr = Err.LastHresult
        If SUCCEEDED(hr) Then
            X3DAudioInitialize wfxFinalMixFormat.dwChannelMask, nSpeedOfSound, X3DInstance
        End If
    End If

    XACT3DInitialize = hr
End Function

Public Function XACT3DCalculate(X3DInstance As X3DAUDIO_HANDLE, pListener As X3DAUDIO_LISTENER, pEmitter As X3DAUDIO_EMITTER, pDSPSettings As X3DAUDIO_DSP_SETTINGS) As Long ' HRESULT
    Dim hr As Long
    hr = S_OK

    If (VarPtr(pListener) = 0) Or (VarPtr(pEmitter) = 0) Or (VarPtr(pDSPSettings) = 0) Then
        hr = E_POINTER
    End If

    If SUCCEEDED(hr) Then
        If (pEmitter.ChannelCount > 1) And (pEmitter.pChannelAzimuths = 0) Then
            pEmitter.ChannelRadius = 1.0!
            Select Case pEmitter.ChannelCount
                Case 2: pEmitter.pChannelAzimuths = VarPtr(aStereoLayout(0))
                Case 3: pEmitter.pChannelAzimuths = VarPtr(a2Point1Layout(0))
                Case 4: pEmitter.pChannelAzimuths = VarPtr(aQuadLayout(0))
                Case 5: pEmitter.pChannelAzimuths = VarPtr(a4Point1Layout(0))
                Case 6: pEmitter.pChannelAzimuths = VarPtr(a5Point1Layout(0))
                Case 8: pEmitter.pChannelAzimuths = VarPtr(a7Point1Layout(0))
                Case Else: hr = E_FAIL
            End Select
        End If
    End If

    If SUCCEEDED(hr) Then
        ' Static arrays initialized once - declare at module level if truly static
        Dim DefaultCurvePoints(0 To 1) As X3DAUDIO_DISTANCE_CURVE_POINT
        DefaultCurvePoints(0).Distance = 0.0!
        DefaultCurvePoints(0).DSPSetting = 1.0!
        DefaultCurvePoints(1).Distance = 1.0!
        DefaultCurvePoints(1).DSPSetting = 1.0!

        Dim DefaultCurve As X3DAUDIO_DISTANCE_CURVE
        DefaultCurve.pPoints = VarPtr(DefaultCurvePoints(0))
        DefaultCurve.PointCount = 2

        If pEmitter.pVolumeCurve = 0 Then
            pEmitter.pVolumeCurve = VarPtr(DefaultCurve)
        End If
        If pEmitter.pLFECurve = 0 Then
            pEmitter.pLFECurve = VarPtr(DefaultCurve)
        End If

        X3DAudioCalculate X3DInstance, pListener, pEmitter, _
            (X3DAUDIO_CALCULATE_MATRIX Or X3DAUDIO_CALCULATE_DOPPLER Or X3DAUDIO_CALCULATE_EMITTER_ANGLE), _
            pDSPSettings
    End If

    XACT3DCalculate = hr
End Function

Public Function XACT3DApply(pDSPSettings As X3DAUDIO_DSP_SETTINGS, pCue As IXACT3Cue) As Long ' HRESULT
    Dim hr As Long
    hr = S_OK

    If VarPtr(pDSPSettings) = 0 Or pCue Is Nothing Then
        hr = E_POINTER
    End If

    If SUCCEEDED(hr) Then
        pCue.SetMatrixCoefficients pDSPSettings.SrcChannelCount, pDSPSettings.DstChannelCount, CType(Of CTypeHelper(Of Single))(pDSPSettings.pMatrixCoefficients).x
        hr = Err.LastHresult
    End If

    If SUCCEEDED(hr) Then
        Dim xactDistanceID As XACTVARIABLEINDEX
        xactDistanceID = pCue.GetVariableIndex(StrPtr(CStr(StrConv("Distance", vbFromUnicode))))
        hr = Err.LastHresult
        If SUCCEEDED(hr) Then
            pCue.SetVariable xactDistanceID, pDSPSettings.EmitterToListenerDistance
            hr = Err.LastHresult
        End If
    End If

    If SUCCEEDED(hr) Then
        Dim xactDopplerID As XACTVARIABLEINDEX
        xactDopplerID = pCue.GetVariableIndex(StrPtr(CStr(StrConv("DopplerPitchScalar", vbFromUnicode))))
        hr = Err.LastHresult
        If SUCCEEDED(hr) Then
            pCue.SetVariable xactDopplerID, pDSPSettings.DopplerFactor
            hr = Err.LastHresult
        End If
    End If

    If SUCCEEDED(hr) Then
        Dim xactOrientationID As XACTVARIABLEINDEX
        xactOrientationID = pCue.GetVariableIndex(StrPtr(CStr(StrConv("OrientationAngle", vbFromUnicode))))
        hr = Err.LastHresult
        If SUCCEEDED(hr) Then
            pCue.SetVariable xactOrientationID, pDSPSettings.EmitterToListenerAngle * (180.0! / X3DAUDIO_PI)
            hr = Err.LastHresult
        End If
    End If

    XACT3DApply = hr
End Function

#End Region



End Module

#End If